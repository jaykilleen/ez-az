<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

  .tv {
    width: 100vw;
    height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    grid-template-columns: minmax(0, 1fr);
    padding: 3vh 4vw;
    gap: 2vh;
    background:
      radial-gradient(ellipse at top right, rgba(0, 255, 200, 0.08), transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(255, 0, 170, 0.06), transparent 50%),
      #0a0a12;
  }

  .tv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3vw;
    overflow: hidden;
  }

  .tv-brand {
    display: flex;
    align-items: baseline;
    gap: 1.5vw;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
  }

  .tv-logo {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(2rem, 5vw, 5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.04em;
    background: linear-gradient(to right, #ff6ec7, #00ffc8, #ffe44d);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: neonFlicker 4s ease-in-out infinite;
  }

  @keyframes neonFlicker {
    0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% { opacity: 1; }
    20%, 24%, 55% { opacity: 0.6; }
  }

  .tv-tagline {
    font-size: clamp(0.7rem, 1.2vw, 1.2rem);
    color: #8ab4c8;
    font-weight: 500;
  }

  .tv-qr {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 1.2vw;
    padding: 1.2vh 1.4vw;
    background: rgba(0, 255, 200, 0.06);
    border: 2px solid rgba(0, 255, 200, 0.3);
    border-radius: 1vw;
  }

  .tv-qr-label {
    text-align: right;
    font-size: clamp(0.85rem, 1.1vw, 1.2rem);
    color: #cfe;
    line-height: 1.3;
  }

  .tv-qr-label strong {
    display: block;
    color: #00ffc8;
    font-size: clamp(1rem, 1.4vw, 1.5rem);
    margin-bottom: 0.3vh;
  }

  .tv-qr-code {
    width: clamp(110px, 11vw, 180px);
    height: clamp(110px, 11vw, 180px);
    background: #0a0a12;
    padding: 0.6vw;
    border-radius: 0.6vw;
    flex-shrink: 0;
  }

  .tv-qr-code svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .tv-cast-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6vw;
    padding: 0.8vh 1.2vw;
    background: rgba(0, 255, 200, 0.06);
    border: 2px solid rgba(0, 255, 200, 0.25);
    border-radius: 0.8vw;
    color: #8ab4c8;
    font-size: clamp(0.8rem, 1vw, 1.1rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    flex-shrink: 0;
  }

  .tv-cast-btn:hover, .tv-cast-btn:focus {
    background: rgba(0, 255, 200, 0.14);
    border-color: #00ffc8;
    color: #00ffc8;
    outline: none;
  }

  .tv-cast-btn svg {
    width: 1.4em;
    height: 1.4em;
    fill: currentColor;
  }

  .tv-greeting {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 2vw;
    padding: 1.5vh 0;
  }

  .az-wrap {
    width: clamp(90px, 10vw, 160px);
    height: clamp(90px, 10vw, 160px);
    position: relative;
    animation: bob 3s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-8px) rotate(2deg); }
  }

  .az-svg {
    width: 100%;
    height: 100%;
  }

  .tv-speech {
    font-size: clamp(1.3rem, 2.5vw, 2.6rem);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
  }

  .tv-speech em {
    color: #00ffc8;
    font-style: normal;
  }

  .tv-main {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }

  .tv-shelf {
    display: flex;
    gap: 2vw;
    overflow: hidden;
    padding: 3vh 0;
    align-items: stretch;
  }

  .tv-game {
    flex: 0 0 auto;
    width: clamp(140px, 14vw, 200px);
    background: linear-gradient(135deg, #13131f, #1a1a2e);
    border: 3px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.2vw;
    padding: 1.5vh 1vw;
    display: flex;
    flex-direction: column;
    gap: 1vh;
    text-decoration: none;
    color: inherit;
    transition: transform 180ms ease-out, border-color 180ms, box-shadow 180ms;
    position: relative;
    outline: none;
  }

  .tv-game:focus,
  .tv-game.is-focused {
    transform: scale(1.08) translateY(-1vh);
    border-color: #00ffc8;
    box-shadow:
      0 0 0 6px rgba(0, 255, 200, 0.2),
      0 20px 50px rgba(0, 255, 200, 0.35),
      inset 0 0 40px rgba(0, 255, 200, 0.08);
    z-index: 2;
  }

  .tv-game-icon {
    width: 100%;
    aspect-ratio: 11 / 14;
    border-radius: 0.6vw;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
  }

  .tv-game-icon canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .tv-game-title {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(0.55rem, 0.8vw, 0.9rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.4;
  }

  .tv-game-creators {
    font-size: clamp(0.75rem, 0.9vw, 1rem);
    color: #00ffc8;
    font-weight: 600;
  }

  .tv-game-tagline {
    font-size: clamp(0.7rem, 0.85vw, 0.95rem);
    color: #8ab4c8;
    line-height: 1.35;
    flex: 1;
  }

  .tv-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2vh;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tv-hint {
    display: flex;
    align-items: center;
    gap: 1vw;
    font-size: clamp(0.95rem, 1.3vw, 1.4rem);
    color: #cfe;
  }

  .tv-key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.4em;
    height: 2em;
    padding: 0 0.7em;
    background: rgba(0, 255, 200, 0.12);
    border: 2px solid rgba(0, 255, 200, 0.4);
    border-radius: 0.4em;
    color: #00ffc8;
    font-weight: 700;
    font-family: "Courier New", monospace;
  }

  .tv-learn-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6vw;
    padding: 0.8vh 1.4vw;
    background: rgba(0, 255, 200, 0.08);
    border: 2px solid rgba(0, 255, 200, 0.35);
    border-radius: 0.8vw;
    color: #00ffc8;
    text-decoration: none;
    font-size: clamp(0.9rem, 1.2vw, 1.3rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
  }

  .tv-learn-btn:focus, .tv-learn-btn:hover {
    background: rgba(0, 255, 200, 0.18);
    border-color: #00ffc8;
    box-shadow: 0 0 0 4px rgba(0,255,200,0.2);
    outline: none;
  }

  .tv-status {
    font-size: clamp(0.85rem, 1.1vw, 1.1rem);
    color: #667;
  }

  .tv-status .dot {
    display: inline-block;
    width: 0.7em;
    height: 0.7em;
    background: #00ffc8;
    border-radius: 50%;
    margin-right: 0.5em;
    vertical-align: middle;
    box-shadow: 0 0 8px #00ffc8;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>

<% cover_ids = {
  'space-dodge'  => 'spaceDodgeCover',
  'dodgeball'    => 'dodgeballCover',
  'corrupted'    => 'corruptedCover',
  'descent'      => 'descentCover',
  'cat-vs-mouse' => 'catMouseCover',
  'bloom'        => 'bloomCover',
  'az-cipher'    => 'cipherCover',
  'trivia'       => 'triviaCover'
} %>

<div class="tv">
  <header class="tv-header">
    <div class="tv-brand">
      <div class="tv-logo">EZ-AZ</div>
      <div class="tv-tagline">The Family Video Game Store</div>
    </div>
    <button class="tv-cast-btn" id="tv-cast-btn" hidden title="Cast to TV">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M1 18v3h3a3 3 0 0 0-3-3zm0-4v2a7 7 0 0 1 7 7h2a9 9 0 0 0-9-9zm0-4v2a13 13 0 0 1 13 13h2A15 15 0 0 0 1 10zm20-6H3C1.9 4 1 4.9 1 6v3h2V6h18v12h-7v2h7c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2z"/>
      </svg>
      Cast
    </button>
    <div class="tv-qr">
      <div class="tv-qr-label">
        <strong>Scan to control &amp; play</strong>
        ez-az.net
      </div>
      <div class="tv-qr-code"><%= @qr_code_svg %></div>
    </div>
  </header>

  <section class="tv-greeting">
    <div class="az-wrap" aria-hidden="true">
      <svg class="az-svg" viewBox="0 0 100 100">
        <!-- Az the dinosaur -->
        <ellipse cx="50" cy="70" rx="32" ry="22" fill="#4caf50"/>
        <ellipse cx="50" cy="45" rx="28" ry="26" fill="#66bb6a"/>
        <!-- Spikes -->
        <polygon points="30,25 34,12 38,25" fill="#2e7d32"/>
        <polygon points="42,20 46,7 50,20" fill="#2e7d32"/>
        <polygon points="54,20 58,7 62,20" fill="#2e7d32"/>
        <polygon points="66,25 70,12 74,25" fill="#2e7d32"/>
        <!-- Eyes -->
        <circle cx="40" cy="42" r="6" fill="#fff"/>
        <circle cx="60" cy="42" r="6" fill="#fff"/>
        <circle cx="41" cy="43" r="3" fill="#000"/>
        <circle cx="61" cy="43" r="3" fill="#000"/>
        <!-- Mouth -->
        <path d="M 38 58 Q 50 66 62 58" stroke="#2e7d32" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <!-- Tail -->
        <path d="M 78 75 Q 92 70 88 55" stroke="#4caf50" stroke-width="6" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="tv-speech">
      Welcome! Pick a game with <em>&larr; &rarr;</em> and press <em>OK</em> to play.
    </div>
  </section>

  <section class="tv-main" aria-label="Game shelf">
    <div class="tv-shelf" id="tv-shelf" role="list">
      <% @games.each_with_index do |game, i| %>
        <% canvas_id = cover_ids[game[:slug]] %>
        <a class="tv-game" role="listitem" href="<%= game[:path] %>" data-index="<%= i %>" tabindex="<%= i == 0 ? 0 : -1 %>">
          <div class="tv-game-icon">
            <% if canvas_id %>
              <canvas id="<%= canvas_id %>" width="220" height="280" style="width:100%;height:100%;display:block;"></canvas>
            <% end %>
          </div>
          <div class="tv-game-title"><%= game[:title] %></div>
          <div class="tv-game-creators">by <%= game[:creators] %></div>
          <div class="tv-game-tagline"><%= game[:tagline] %></div>
        </a>
      <% end %>
    </div>
  </section>

  <footer class="tv-footer">
    <a href="/learn" class="tv-learn-btn" id="tv-learn-btn">
      📚 Learning Center
    </a>
    <div class="tv-hint">
      <span class="tv-key">&larr;</span>
      <span class="tv-key">&rarr;</span>
      <span>Browse</span>
      <span class="tv-key">OK</span>
      <span>Play</span>
      <span class="tv-key">BACK</span>
      <span>Menu</span>
    </div>
    <div class="tv-status"><span class="dot"></span>Ready</div>
  </footer>
</div>

<script>
  (function() {
    var shelf    = document.getElementById('tv-shelf');
    var games    = Array.prototype.slice.call(shelf.querySelectorAll('.tv-game'));
    var learnBtn = document.getElementById('tv-learn-btn');
    var focusedIndex = 0;
    var learnFocused = false;

    function focusGame(index) {
      index = Math.max(0, Math.min(games.length - 1, index));
      games.forEach(function(g, i) {
        g.tabIndex = i === index ? 0 : -1;
        g.classList.toggle('is-focused', i === index);
      });
      learnBtn.tabIndex = -1;
      learnFocused = false;
      focusedIndex = index;
      games[index].focus();
      scrollIntoView(games[index]);
    }

    function focusLearn() {
      games.forEach(function(g) { g.tabIndex = -1; g.classList.remove('is-focused'); });
      learnBtn.tabIndex = 0;
      learnFocused = true;
      learnBtn.focus();
    }

    function scrollIntoView(el) {
      var r = el.getBoundingClientRect();
      var w = window.innerWidth;
      if (r.left < w * 0.1 || r.right > w * 0.9) {
        el.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    }

    document.addEventListener('keydown', function(e) {
      switch (e.key) {
        case 'ArrowLeft':
          e.preventDefault();
          if (learnFocused) { focusGame(games.length - 1); }
          else { focusGame(focusedIndex - 1); }
          break;
        case 'ArrowRight':
          e.preventDefault();
          if (learnFocused) break;
          if (focusedIndex === games.length - 1) { focusLearn(); }
          else { focusGame(focusedIndex + 1); }
          break;
        case 'ArrowDown':
          e.preventDefault();
          focusLearn();
          break;
        case 'ArrowUp':
          e.preventDefault();
          if (learnFocused) focusGame(focusedIndex);
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          if (learnFocused) { learnBtn.click(); }
          else { games[focusedIndex].click(); }
          break;
      }
    });

    // Initialize focus
    learnBtn.tabIndex = -1;
    focusGame(0);
  })();
</script>

<script src="/game-covers.js"></script>

<script type="module">
  import { createConsumer } from "<%= asset_path('actioncable.esm.js') %>";

  var token = <%= @remote_token.to_json.html_safe %>;
  sessionStorage.setItem('tvRemoteToken', token);
  var consumer = createConsumer();

  consumer.subscriptions.create(
    { channel: 'TvRemoteChannel', token: token },
    {
      received: function(data) {
        if (data.type !== 'navigate') return;
        var keyMap = {
          left: 'ArrowLeft', right: 'ArrowRight',
          up: 'ArrowUp',     down: 'ArrowDown',
          select: 'Enter',   back: 'Escape'
        };
        var key = keyMap[data.direction];
        if (key) document.dispatchEvent(new KeyboardEvent('keydown', { key: key, bubbles: true }));
      }
    }
  );
</script>

<script>
  (function() {
    var castBtn = document.getElementById('tv-cast-btn');
    if (!('presentation' in navigator)) return;

    var request = new PresentationRequest([window.location.origin + '/tv']);

    request.getAvailability().then(function(a) {
      castBtn.hidden = !a.value;
      a.onchange = function() { castBtn.hidden = !a.value; };
    }).catch(function() {
      // Some browsers don't support getAvailability — show the button anyway
      castBtn.hidden = false;
    });

    castBtn.addEventListener('click', function() {
      request.start().catch(function() {});
    });
  })();
</script>
