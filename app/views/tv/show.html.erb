<style>
  .tv {
    width: 100vw;
    height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 3vh 4vw;
    gap: 2vh;
    background:
      radial-gradient(ellipse at top right, rgba(0, 255, 200, 0.08), transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(255, 0, 170, 0.06), transparent 50%),
      #0a0a12;
  }

  .tv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3vw;
  }

  .tv-brand {
    display: flex;
    align-items: baseline;
    gap: 1.5vw;
  }

  .tv-logo {
    font-size: clamp(3rem, 7vw, 7rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, #00ffc8 0%, #00a3ff 50%, #ff00aa 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: pulse 6s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { filter: drop-shadow(0 0 20px rgba(0, 255, 200, 0.4)); }
    50% { filter: drop-shadow(0 0 35px rgba(255, 0, 170, 0.5)); }
  }

  .tv-tagline {
    font-size: clamp(1rem, 1.8vw, 1.8rem);
    color: #8ab4c8;
    font-weight: 500;
  }

  .tv-qr {
    display: flex;
    align-items: center;
    gap: 1.2vw;
    padding: 1.2vh 1.4vw;
    background: rgba(0, 255, 200, 0.06);
    border: 2px solid rgba(0, 255, 200, 0.3);
    border-radius: 1vw;
  }

  .tv-qr-label {
    text-align: right;
    font-size: clamp(0.85rem, 1.1vw, 1.2rem);
    color: #cfe;
    line-height: 1.3;
  }

  .tv-qr-label strong {
    display: block;
    color: #00ffc8;
    font-size: clamp(1rem, 1.4vw, 1.5rem);
    margin-bottom: 0.3vh;
  }

  .tv-qr svg {
    width: clamp(110px, 11vw, 180px);
    height: clamp(110px, 11vw, 180px);
    background: #0a0a12;
    padding: 0.6vw;
    border-radius: 0.6vw;
  }

  .tv-greeting {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 2vw;
    padding: 1.5vh 0;
  }

  .az-wrap {
    width: clamp(90px, 10vw, 160px);
    height: clamp(90px, 10vw, 160px);
    position: relative;
    animation: bob 3s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-8px) rotate(2deg); }
  }

  .az-svg {
    width: 100%;
    height: 100%;
  }

  .tv-speech {
    font-size: clamp(1.3rem, 2.5vw, 2.6rem);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
  }

  .tv-speech em {
    color: #00ffc8;
    font-style: normal;
  }

  .tv-main {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }

  .tv-shelf {
    display: flex;
    gap: 2vw;
    overflow: hidden;
    padding: 3vh 0;
    align-items: stretch;
  }

  .tv-game {
    flex: 0 0 22vw;
    min-width: 220px;
    background: linear-gradient(135deg, #13131f, #1a1a2e);
    border: 3px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.2vw;
    padding: 2.5vh 1.5vw;
    display: flex;
    flex-direction: column;
    gap: 1.2vh;
    text-decoration: none;
    color: inherit;
    transition: transform 180ms ease-out, border-color 180ms, box-shadow 180ms;
    position: relative;
    outline: none;
  }

  .tv-game:focus,
  .tv-game.is-focused {
    transform: scale(1.08) translateY(-1vh);
    border-color: #00ffc8;
    box-shadow:
      0 0 0 6px rgba(0, 255, 200, 0.2),
      0 20px 50px rgba(0, 255, 200, 0.35),
      inset 0 0 40px rgba(0, 255, 200, 0.08);
    z-index: 2;
  }

  .tv-game-icon {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 0.6vw;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tv-game-title {
    font-size: clamp(1.3rem, 1.8vw, 2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .tv-game-creators {
    font-size: clamp(0.85rem, 1.1vw, 1.1rem);
    color: #00ffc8;
    font-weight: 600;
  }

  .tv-game-tagline {
    font-size: clamp(0.8rem, 1vw, 1rem);
    color: #8ab4c8;
    line-height: 1.35;
    flex: 1;
  }

  .tv-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2vh;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tv-hint {
    display: flex;
    align-items: center;
    gap: 1vw;
    font-size: clamp(0.95rem, 1.3vw, 1.4rem);
    color: #cfe;
  }

  .tv-key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.4em;
    height: 2em;
    padding: 0 0.7em;
    background: rgba(0, 255, 200, 0.12);
    border: 2px solid rgba(0, 255, 200, 0.4);
    border-radius: 0.4em;
    color: #00ffc8;
    font-weight: 700;
    font-family: "Courier New", monospace;
  }

  .tv-status {
    font-size: clamp(0.85rem, 1.1vw, 1.1rem);
    color: #667;
  }

  .tv-status .dot {
    display: inline-block;
    width: 0.7em;
    height: 0.7em;
    background: #00ffc8;
    border-radius: 50%;
    margin-right: 0.5em;
    vertical-align: middle;
    box-shadow: 0 0 8px #00ffc8;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Game icon styles per-slug */
  .icon-svg { width: 80%; height: 80%; }
</style>

<div class="tv">
  <header class="tv-header">
    <div class="tv-brand">
      <div class="tv-logo">EZ-AZ</div>
      <div class="tv-tagline">The Family Video Game Store</div>
    </div>
    <div class="tv-qr">
      <div class="tv-qr-label">
        <strong>Scan to play on your phone</strong>
        ez-az.net
      </div>
      <%= @qr_code_svg %>
    </div>
  </header>

  <section class="tv-greeting">
    <div class="az-wrap" aria-hidden="true">
      <svg class="az-svg" viewBox="0 0 100 100">
        <!-- Az the dinosaur -->
        <ellipse cx="50" cy="70" rx="32" ry="22" fill="#4caf50"/>
        <ellipse cx="50" cy="45" rx="28" ry="26" fill="#66bb6a"/>
        <!-- Spikes -->
        <polygon points="30,25 34,12 38,25" fill="#2e7d32"/>
        <polygon points="42,20 46,7 50,20" fill="#2e7d32"/>
        <polygon points="54,20 58,7 62,20" fill="#2e7d32"/>
        <polygon points="66,25 70,12 74,25" fill="#2e7d32"/>
        <!-- Eyes -->
        <circle cx="40" cy="42" r="6" fill="#fff"/>
        <circle cx="60" cy="42" r="6" fill="#fff"/>
        <circle cx="41" cy="43" r="3" fill="#000"/>
        <circle cx="61" cy="43" r="3" fill="#000"/>
        <!-- Mouth -->
        <path d="M 38 58 Q 50 66 62 58" stroke="#2e7d32" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <!-- Tail -->
        <path d="M 78 75 Q 92 70 88 55" stroke="#4caf50" stroke-width="6" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="tv-speech">
      Welcome! Pick a game with <em>&larr; &rarr;</em> and press <em>OK</em> to play.
    </div>
  </section>

  <section class="tv-main" aria-label="Game shelf">
    <div class="tv-shelf" id="tv-shelf" role="list">
      <% @games.each_with_index do |game, i| %>
        <a class="tv-game" role="listitem" href="<%= game[:path] %>" data-index="<%= i %>" tabindex="<%= i == 0 ? 0 : -1 %>">
          <div class="tv-game-icon">
            <%= game_icon_svg(game[:icon]) %>
          </div>
          <div class="tv-game-title"><%= game[:title] %></div>
          <div class="tv-game-creators">by <%= game[:creators] %></div>
          <div class="tv-game-tagline"><%= game[:tagline] %></div>
        </a>
      <% end %>
    </div>
  </section>

  <footer class="tv-footer">
    <div class="tv-hint">
      <span class="tv-key">&larr;</span>
      <span class="tv-key">&rarr;</span>
      <span>Browse</span>
      <span class="tv-key">OK</span>
      <span>Play</span>
      <span class="tv-key">BACK</span>
      <span>Menu</span>
    </div>
    <div class="tv-status"><span class="dot"></span>Ready</div>
  </footer>
</div>

<script>
  (function() {
    var shelf = document.getElementById('tv-shelf');
    var games = Array.prototype.slice.call(shelf.querySelectorAll('.tv-game'));
    var focusedIndex = 0;

    function focus(index) {
      index = Math.max(0, Math.min(games.length - 1, index));
      games.forEach(function(g, i) {
        g.tabIndex = i === index ? 0 : -1;
        g.classList.toggle('is-focused', i === index);
      });
      focusedIndex = index;
      games[index].focus();
      scrollIntoView(games[index]);
    }

    function scrollIntoView(el) {
      var r = el.getBoundingClientRect();
      var w = window.innerWidth;
      if (r.left < w * 0.1 || r.right > w * 0.9) {
        el.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    }

    document.addEventListener('keydown', function(e) {
      switch (e.key) {
        case 'ArrowLeft':
          e.preventDefault();
          focus(focusedIndex - 1);
          break;
        case 'ArrowRight':
          e.preventDefault();
          focus(focusedIndex + 1);
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          games[focusedIndex].click();
          break;
      }
    });

    // Initialize focus
    focus(0);
  })();
</script>
