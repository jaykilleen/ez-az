<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

  .tv {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr auto;
    grid-template-columns: minmax(0, 1fr);
    padding: 3vh 4vw;
    gap: 2vh;
    background:
      radial-gradient(ellipse at top right, rgba(0, 255, 200, 0.08), transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(255, 0, 170, 0.06), transparent 50%),
      #0a0a12;
  }

  .tv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3vw;
    overflow: hidden;
  }

  .tv-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4vh;
    flex: 1 1 auto;
    min-width: 0;
  }

  .tv-version {
    font-family: "Courier New", monospace;
    font-size: clamp(0.55rem, 0.75vw, 0.8rem);
    color: #335;
    letter-spacing: 0.06em;
  }

  .tv-logo {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(2rem, 5vw, 5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.04em;
    background: linear-gradient(to right, #ff6ec7, #00ffc8, #ffe44d);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
    animation: neonFlicker 4s infinite;
  }

  @keyframes neonFlicker {
    0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% { opacity: 1; }
    20%, 24%, 55% { opacity: 0.6; }
  }

  .tv-tagline {
    font-size: clamp(0.7rem, 1.2vw, 1.2rem);
    color: #888;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .tv-qr {
    flex: 0 0 auto;
  }

  .tv-qr-code {
    width: clamp(90px, 9vw, 150px);
    height: clamp(90px, 9vw, 150px);
    background: #0a0a12;
    padding: 0.5vw;
    border-radius: 0.8vw;
    border: 2px solid rgba(0, 255, 200, 0.3);
  }

  .tv-qr-code svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .tv-main {
    min-height: 0;
    overflow: hidden;
    scroll-behavior: smooth;
  }

  .tv-shelf {
    display: grid;
    grid-template-columns: repeat(var(--tv-cols, 5), clamp(140px, 14vw, 220px));
    justify-content: center;
    gap: 1.5vw;
    padding: 2vh 0 1vh;
  }

  .tv-game {
    background: linear-gradient(135deg, #13131f, #1a1a2e);
    border: 3px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.2vw;
    padding: 1vh 0.8vw;
    display: flex;
    flex-direction: column;
    gap: 0.6vh;
    text-decoration: none;
    color: inherit;
    transition: transform 180ms ease-out, border-color 180ms, box-shadow 180ms;
    position: relative;
    outline: none;
  }

  .tv-game:focus,
  .tv-game.is-focused {
    transform: scale(1.05);
    border-color: #00ffc8;
    box-shadow:
      0 0 0 6px rgba(0, 255, 200, 0.2),
      0 20px 50px rgba(0, 255, 200, 0.35),
      inset 0 0 40px rgba(0, 255, 200, 0.08);
    z-index: 2;
  }

  .tv-game-icon {
    width: 100%;
    aspect-ratio: 11 / 14;
    max-height: 16vh;
    border-radius: 0.6vw;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
  }

  .tv-game-icon canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .tv-game-title {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(0.55rem, 0.8vw, 0.9rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.4;
  }

  .tv-game-creators {
    font-size: clamp(0.75rem, 0.9vw, 1rem);
    color: #00ffc8;
    font-weight: 600;
  }

  .tv-game-tagline {
    font-size: clamp(0.7rem, 0.85vw, 0.95rem);
    color: #8ab4c8;
    line-height: 1.35;
    flex: 1;
  }

  .tv-game.coming-soon {
    cursor: default;
    border-style: dashed;
    border-color: #1e1e30;
    opacity: 0.5;
    pointer-events: none;
  }

  .tv-game-icon.placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0e0e1a;
  }

  .tv-placeholder-text {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(0.45rem, 0.6vw, 0.7rem);
    color: #2a2a3e;
    text-align: center;
    line-height: 1.8;
  }

  .tv-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5vh;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    gap: 2vw;
  }

  .tv-footer-left {
    display: flex;
    align-items: center;
    gap: 0.8vw;
    flex-shrink: 0;
  }

  .tv-cast-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5vw;
    padding: 0.8vh 1.2vw;
    background: rgba(0, 255, 200, 0.06);
    border: 2px solid rgba(0, 255, 200, 0.25);
    border-radius: 0.8vw;
    color: #8ab4c8;
    font-size: clamp(0.9rem, 1.2vw, 1.3rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .tv-cast-btn:hover, .tv-cast-btn:focus {
    background: rgba(0, 255, 200, 0.14);
    border-color: #00ffc8;
    color: #00ffc8;
    outline: none;
  }

  .tv-cast-btn svg {
    width: 1.2em;
    height: 1.2em;
    fill: currentColor;
    flex-shrink: 0;
  }

  .tv-reload-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4vw;
    padding: 0.8vh 1.2vw;
    background: rgba(255, 255, 255, 0.04);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.8vw;
    color: #445;
    font-size: clamp(0.9rem, 1.2vw, 1.3rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    font-family: inherit;
  }

  .tv-reload-btn:hover, .tv-reload-btn:focus {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: #889;
    outline: none;
  }


  .tv-learn-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6vw;
    padding: 0.8vh 1.4vw;
    background: rgba(0, 255, 200, 0.08);
    border: 2px solid rgba(0, 255, 200, 0.35);
    border-radius: 0.8vw;
    color: #00ffc8;
    text-decoration: none;
    font-size: clamp(0.9rem, 1.2vw, 1.3rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
  }

  .tv-learn-btn:focus, .tv-learn-btn:hover {
    background: rgba(0, 255, 200, 0.18);
    border-color: #00ffc8;
    box-shadow: 0 0 0 4px rgba(0,255,200,0.2);
    outline: none;
  }

  .tv-status {
    font-size: clamp(0.85rem, 1.1vw, 1.1rem);
    color: #667;
  }

  .tv-status .dot {
    display: inline-block;
    width: 0.7em;
    height: 0.7em;
    background: #00ffc8;
    border-radius: 50%;
    margin-right: 0.5em;
    vertical-align: middle;
    box-shadow: 0 0 8px #00ffc8;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>

<% cover_ids = {
  'space-dodge'  => 'spaceDodgeCover',
  'dodgeball'    => 'dodgeballCover',
  'corrupted'    => 'corruptedCover',
  'descent'      => 'descentCover',
  'cat-vs-mouse' => 'catMouseCover',
  'bloom'        => 'bloomCover',
  'az-cipher'    => 'cipherCover',
  'trivia'       => 'triviaCover'
} %>

<div class="tv">
  <header class="tv-header">
    <div class="tv-brand">
      <div class="tv-logo">EZ-AZ</div>
      <div class="tv-tagline">The Family Video Game Store</div>
      <div class="tv-version">v<%= @version %></div>
    </div>
    <div class="tv-qr">
      <div class="tv-qr-code"><%= @qr_code_svg %></div>
    </div>
  </header>

  <section class="tv-main" aria-label="Game shelf">
    <div class="tv-shelf" id="tv-shelf" role="list" style="--tv-cols: <%= @tv_cols %>">
      <% @games.each_with_index do |game, i| %>
        <% canvas_id = cover_ids[game[:slug]] %>
        <a class="tv-game" role="listitem" href="<%= game[:path] %>" data-index="<%= i %>" tabindex="<%= i == 0 ? 0 : -1 %>">
          <div class="tv-game-icon">
            <% if canvas_id %>
              <canvas id="<%= canvas_id %>" width="220" height="280" style="width:100%;height:100%;display:block;"></canvas>
            <% end %>
          </div>
          <div class="tv-game-title"><%= game[:title] %></div>
          <div class="tv-game-creators">by <%= game[:creators] %></div>
          <div class="tv-game-tagline"><%= game[:tagline] %></div>
        </a>
      <% end %>
      <% @coming_to_tv.each do |game| %>
        <div class="tv-game coming-soon" role="listitem" aria-hidden="true">
          <div class="tv-game-icon placeholder">
            <div class="tv-placeholder-text">COMING<br>SOON</div>
          </div>
          <div class="tv-game-title"><%= game[:title] %></div>
          <div class="tv-game-creators">by <%= game[:creators] %></div>
          <div class="tv-game-tagline"><%= game[:tagline] %></div>
        </div>
      <% end %>
    </div>
  </section>

  <footer class="tv-footer">
    <div class="tv-footer-left">
      <a href="/learn" class="tv-learn-btn" id="tv-learn-btn">📚 Learning Center</a>
      <a href="/scan" class="tv-cast-btn">Scan for Party</a>
      <button class="tv-cast-btn" id="tv-cast-btn" hidden title="Cast to TV">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M1 18v3h3a3 3 0 0 0-3-3zm0-4v2a7 7 0 0 1 7 7h2a9 9 0 0 0-9-9zm0-4v2a13 13 0 0 1 13 13h2A15 15 0 0 0 1 10zm20-6H3C1.9 4 1 4.9 1 6v3h2V6h18v12h-7v2h7c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2z"/>
        </svg>
        Cast
      </button>
      <button class="tv-reload-btn" onclick="window.location.reload()" title="Reload page">&#8635; Reload</button>
    </div>
    <div class="tv-status"><span class="dot"></span>Ready</div>
  </footer>
</div>

<script>
  (function() {
    var shelf    = document.getElementById('tv-shelf');
    var games    = Array.prototype.slice.call(shelf.querySelectorAll('.tv-game'));
    var learnBtn = document.getElementById('tv-learn-btn');
    var focusedIndex = 0;
    var learnFocused = false;
    var COLS = parseInt(shelf.style.getPropertyValue('--tv-cols')) || 5;

    function focusGame(index) {
      index = Math.max(0, Math.min(games.length - 1, index));
      games.forEach(function(g, i) {
        g.tabIndex = i === index ? 0 : -1;
        g.classList.toggle('is-focused', i === index);
      });
      learnBtn.tabIndex = -1;
      learnFocused = false;
      focusedIndex = index;
      games[index].focus();
      games[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
    }

    function focusLearn() {
      games.forEach(function(g) { g.tabIndex = -1; g.classList.remove('is-focused'); });
      learnBtn.tabIndex = 0;
      learnFocused = true;
      learnBtn.focus();
    }

    document.addEventListener('keydown', function(e) {
      var col = focusedIndex % COLS;
      var lastRow = Math.floor((games.length - 1) / COLS);
      var row = Math.floor(focusedIndex / COLS);

      switch (e.key) {
        case 'ArrowLeft':
          e.preventDefault();
          if (learnFocused) { focusGame(focusedIndex); break; }
          if (col > 0) focusGame(focusedIndex - 1);
          break;
        case 'ArrowRight':
          e.preventDefault();
          if (learnFocused) break;
          if (col < COLS - 1 && focusedIndex + 1 < games.length) focusGame(focusedIndex + 1);
          break;
        case 'ArrowDown':
          e.preventDefault();
          if (learnFocused) break;
          if (row < lastRow) focusGame(Math.min(focusedIndex + COLS, games.length - 1));
          else focusLearn();
          break;
        case 'ArrowUp':
          e.preventDefault();
          if (learnFocused) { focusGame(focusedIndex); break; }
          if (row > 0) focusGame(focusedIndex - COLS);
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          if (learnFocused) { learnBtn.click(); }
          else { games[focusedIndex].click(); }
          break;
      }
    });

    // Initialize focus
    learnBtn.tabIndex = -1;
    focusGame(0);
  })();
</script>

<script src="/game-covers.js"></script>

<script type="module">
  import { createConsumer } from "<%= asset_path('actioncable.esm.js') %>";

  var token = <%= @remote_token.to_json.html_safe %>;
  sessionStorage.setItem('tvRemoteToken', token);
  sessionStorage.setItem('tvAcPath', '<%= asset_path("actioncable.esm.js") %>');
  var consumer = createConsumer();

  consumer.subscriptions.create(
    { channel: 'TvRemoteChannel', token: token },
    {
      connected: function() {
        this.perform('set_state', { state: 'shelf' });
      },
      received: function(data) {
        if (data.type !== 'navigate') return;
        var keyMap = {
          left: 'ArrowLeft', right: 'ArrowRight',
          up: 'ArrowUp',     down: 'ArrowDown',
          select: 'Enter',   back: 'Escape'
        };
        var key = keyMap[data.direction];
        if (key) document.dispatchEvent(new KeyboardEvent('keydown', { key: key, bubbles: true }));
      }
    }
  );
</script>

<script>
  (function() {
    var castBtn = document.getElementById('tv-cast-btn');
    if (!('presentation' in navigator)) return;

    var request = new PresentationRequest([window.location.origin + '/tv']);

    request.getAvailability().then(function(a) {
      castBtn.hidden = !a.value;
      a.onchange = function() { castBtn.hidden = !a.value; };
    }).catch(function() {
      // Some browsers don't support getAvailability — show the button anyway
      castBtn.hidden = false;
    });

    castBtn.addEventListener('click', function() {
      request.start().catch(function() {});
    });
  })();
</script>
