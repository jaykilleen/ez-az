<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0a0a12">
  <title>Watch — EZ-AZ</title>
  <link rel="icon" type="image/png" href="/icons/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
      background: #0a0a12;
      color: #e0e0e0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* --- Player --- */
    .player-wrap {
      position: fixed;
      inset: 0;
      z-index: 0;
      background: #000;
    }

    #yt-player {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    /* --- Header overlay --- */
    .watch-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 10;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 24px 60px;
      background: linear-gradient(to bottom, rgba(10,10,18,0.92) 0%, transparent 100%);
      pointer-events: none;
    }

    .watch-header a { pointer-events: auto; }

    .channel-bar {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .store-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 10px;
      background: rgba(0,255,200,0.1);
      border: 2px solid rgba(0,255,200,0.35);
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(0.6rem, 1vw, 0.85rem);
      font-weight: 900;
      color: #00ffc8;
      text-decoration: none;
      line-height: 1;
      transition: background 0.15s, border-color 0.15s;
      white-space: nowrap;
    }

    .store-link:hover, .store-link:focus {
      background: rgba(0,255,200,0.2);
      border-color: #00ffc8;
      outline: none;
    }

    .ch-divider {
      width: 1px; height: 24px;
      background: rgba(255,255,255,0.2);
    }

    .ch-num {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(0.75rem, 1.5vw, 1.1rem);
      color: #00ffc8;
      line-height: 1;
    }

    .ch-emoji {
      font-size: clamp(1.2rem, 2.5vw, 1.8rem);
      line-height: 1;
    }

    .ch-name {
      font-size: clamp(0.75rem, 1.5vw, 1.1rem);
      font-weight: 800;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .watch-qr {
      width: clamp(70px, 7vw, 110px);
      height: clamp(70px, 7vw, 110px);
      flex-shrink: 0;
      background: #0a0a12;
      padding: 6px;
      border-radius: 8px;
      border: 1px solid rgba(0,255,200,0.25);
    }

    /* --- Footer overlay --- */
    .watch-footer {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 10;
      padding: 80px 24px 24px;
      background: linear-gradient(to top, rgba(10,10,18,0.95) 0%, rgba(10,10,18,0.5) 60%, transparent 100%);
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .watch-footer.hud-visible { opacity: 1; }


    .video-meta { flex: 1; min-width: 0; }

    .video-title {
      font-size: clamp(0.9rem, 1.8vw, 1.3rem);
      font-weight: 700;
      color: #fff;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .video-sub {
      margin-top: 4px;
      font-size: clamp(0.7rem, 1.2vw, 0.95rem);
      color: #888;
      display: flex;
      gap: 12px;
    }

    .video-pos { color: #00ffc8; font-weight: 700; }

    .nav-hint {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .nav-key {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 8px;
      border: 2px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.06);
      font-size: clamp(0.8rem, 1.3vw, 1.1rem);
      font-weight: 700;
      color: #ccc;
      white-space: nowrap;
    }

    .nav-key .k {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      height: 28px;
      border-radius: 6px;
      background: rgba(255,255,255,0.12);
      font-size: 1em;
      color: #fff;
      padding: 0 4px;
    }

    .nav-key.k-channel .k { color: #00ffc8; background: rgba(0,255,200,0.15); }
    .nav-key.k-video   .k { color: #ffe44d; background: rgba(255,228,77,0.15); }
    .nav-key.k-play    .k { color: #ff6ec7; background: rgba(255,110,199,0.15); }
    .nav-key.k-home    .k { color: #aaa;    background: rgba(255,255,255,0.1); }

    /* --- Channel guide bar --- */
    .guide {
      position: fixed;
      bottom: -160px;
      left: 0; right: 0;
      z-index: 20;
      display: flex;
      gap: 12px;
      padding: 16px 24px 20px;
      background: rgba(10, 10, 18, 0.97);
      border-top: 1px solid rgba(255,255,255,0.08);
      overflow-x: auto;
      scrollbar-width: none;
      transition: bottom 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .guide::-webkit-scrollbar { display: none; }

    .guide.visible { bottom: 0; }

    .guide-ch {
      flex: 0 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      padding: 12px 20px;
      border: 2px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      min-width: 130px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      pointer-events: auto;
    }

    .guide-ch:hover { border-color: rgba(255,255,255,0.3); }

    .guide-ch.active {
      border-color: #00ffc8;
      background: rgba(0,255,200,0.1);
    }

    .guide-ch-num {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.55rem;
      color: #555;
    }

    .guide-ch.active .guide-ch-num { color: #00ffc8; }

    .guide-ch-emoji { font-size: 1.6rem; }

    .guide-ch-name {
      font-size: 0.72rem;
      font-weight: 700;
      color: #ccc;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1.2;
    }

    .guide-ch.active .guide-ch-name { color: #fff; }

    /* --- TV Guide overlay (full-screen schedule grid) --- */
    .tv-guide {
      position: fixed;
      inset: 0;
      z-index: 30;
      background: rgba(5, 5, 12, 0.97);
      backdrop-filter: blur(6px);
      display: flex;
      flex-direction: column;
      padding: 32px 48px 32px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
      overflow-y: auto;
    }
    .tv-guide.visible {
      opacity: 1;
      pointer-events: auto;
    }
    .tv-guide-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 20px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      flex-shrink: 0;
    }
    .tv-guide-title {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(1rem, 2vw, 1.6rem);
      color: #00ffc8;
      letter-spacing: 0.06em;
    }
    .tv-guide-clock {
      font-family: 'Press Start 2P', monospace;
      font-size: clamp(0.8rem, 1.4vw, 1.1rem);
      color: #fff;
      letter-spacing: 0.06em;
    }
    .tv-guide-clock-label {
      color: #555;
      font-size: 0.7em;
      margin-right: 8px;
    }
    .tv-guide-rows {
      display: flex;
      flex-direction: column;
      gap: 12px;
      flex: 1;
    }
    .tv-guide-row {
      display: grid;
      grid-template-columns: clamp(140px, 16vw, 240px) 1fr;
      gap: 18px;
      padding: 12px;
      border-radius: 12px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .tv-guide-row:hover { background: rgba(255,255,255,0.06); border-color: rgba(0,255,200,0.3); }
    .tv-guide-row.active {
      border-color: #00ffc8;
      background: rgba(0,255,200,0.08);
    }
    .tv-guide-ch {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 4px;
    }
    .tv-guide-ch-num {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.6rem;
      color: #555;
    }
    .tv-guide-row.active .tv-guide-ch-num { color: #00ffc8; }
    .tv-guide-ch-row {
      display: flex; align-items: center; gap: 10px;
    }
    .tv-guide-ch-emoji { font-size: 1.6rem; line-height: 1; }
    .tv-guide-ch-name {
      font-size: clamp(0.9rem, 1.3vw, 1.1rem);
      font-weight: 800;
      color: #fff;
      letter-spacing: 0.02em;
    }
    .tv-guide-slots {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      min-width: 0;
    }
    .tv-guide-slot {
      padding: 8px 10px;
      border-radius: 8px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .tv-guide-slot.is-now {
      background: rgba(0,255,200,0.1);
      border-color: rgba(0,255,200,0.4);
    }
    .tv-guide-slot-time {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.55rem;
      color: #888;
      letter-spacing: 0.04em;
    }
    .tv-guide-slot.is-now .tv-guide-slot-time { color: #00ffc8; }
    .tv-guide-slot-title {
      font-size: clamp(0.75rem, 0.95vw, 0.95rem);
      font-weight: 700;
      color: #ddd;
      line-height: 1.3;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .tv-guide-slot.is-now .tv-guide-slot-title { color: #fff; }
    .tv-guide-slot-note {
      font-size: 0.7rem;
      color: #555;
      letter-spacing: 0.02em;
    }
    .tv-guide-hint {
      flex-shrink: 0;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid rgba(255,255,255,0.06);
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      font-size: clamp(0.7rem, 1vw, 0.9rem);
      color: #666;
    }
    .tv-guide-hint .k {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 22px;
      padding: 0 6px;
      margin-right: 6px;
      border-radius: 5px;
      background: rgba(255,255,255,0.08);
      color: #ddd;
      font-weight: 700;
    }
  </style>
</head>
<body>

<div class="player-wrap">
  <div id="yt-player"></div>
</div>

<header class="watch-header">
  <div class="channel-bar">
    <a href="/" class="store-link">← Store</a>
    <div class="ch-divider"></div>
    <span class="ch-num"  id="chNum">CH 01</span>
    <span class="ch-emoji" id="chEmoji"></span>
    <span class="ch-name"  id="chName"></span>
  </div>
  <div class="watch-qr"><%= @qr_code_svg %></div>
</header>

<footer class="watch-footer">
  <div class="video-meta">
    <div class="video-title" id="videoTitle"></div>
    <div class="video-sub">
      <span class="video-pos"  id="videoPos"></span>
      <span class="video-note" id="videoNote"></span>
    </div>
    <div class="nav-hint">
      <span class="nav-key k-channel"><span class="k">▲▼</span> Change Channel</span>
      <span class="nav-key k-video"><span class="k">◀▶</span> Skip Video</span>
      <span class="nav-key k-play"><span class="k">●</span> Play / Pause</span>
      <span class="nav-key k-video"><span class="k">G</span> TV Guide</span>
      <span class="nav-key k-home"><span class="k">⌫</span> Go Home</span>
    </div>
  </div>
</footer>

<div class="guide" id="guide">
  <% @tracks.each_with_index do |track, i| %>
    <div class="guide-ch<%= i == 0 ? ' active' : '' %>"
         data-idx="<%= i %>"
         onclick="selectChannel(<%= i %>)">
      <span class="guide-ch-num">CH <%= sprintf('%02d', i + 1) %></span>
      <span class="guide-ch-emoji"><%= track[:emoji] %></span>
      <span class="guide-ch-name"><%= track[:title] %></span>
    </div>
  <% end %>
</div>

<!-- Full-screen TV Guide overlay -->
<section class="tv-guide" id="tvGuide" aria-hidden="true">
  <header class="tv-guide-header">
    <div class="tv-guide-title">📺 TV GUIDE</div>
    <div class="tv-guide-clock">
      <span class="tv-guide-clock-label">NOW</span>
      <span id="tvGuideClock">--:--</span>
    </div>
  </header>
  <div class="tv-guide-rows" id="tvGuideRows"></div>
  <div class="tv-guide-hint">
    <span><span class="k">G</span> Close Guide</span>
    <span><span class="k">▲▼</span> Highlight</span>
    <span><span class="k">●</span> Tune to Channel</span>
  </div>
</section>

<script>
  // Globals needed before YouTube IFrame API calls the callback
  window._ytCallbacks = [];
  window.onYouTubeIframeAPIReady = function() {
    window._ytReady = true;
    window._ytCallbacks.forEach(function(fn) { fn(); });
    window._ytCallbacks = [];
  };
</script>
<script src="https://www.youtube.com/iframe_api"></script>

<script type="module">
  import { createConsumer } from "<%= asset_path('actioncable.esm.js') %>";

  var tracks       = <%= raw @tracks.to_json %>;
  var token        = <%= @room.tv_token.to_json.html_safe %>;
  var trackIdx     = 0;
  var videoIdx     = 0;       // index into the channel's daily-shuffled schedule
  var player       = null;
  var syncTimer    = null;
  var guideTimer   = null;
  var hudTimer     = null;
  var clockTimer   = null;
  var guideHighlight = 0;     // which channel is currently highlighted in the TV Guide
  var footer       = document.querySelector('.watch-footer');

  // ── Scheduler ────────────────────────────────────────────────────────────
  // Each channel has a deterministic per-day shuffle of its videos. The
  // schedule starts at local midnight and loops if total content < 24h. Two
  // viewers tuning in at the same time on the same day always see the same
  // thing. Tomorrow is a different shuffle.

  function dayKey() {
    var d = new Date();
    var start = new Date(d.getFullYear(), 0, 0);
    var diff  = d - start + (start.getTimezoneOffset() - d.getTimezoneOffset()) * 60 * 1000;
    return d.getFullYear() * 1000 + Math.floor(diff / 86400000);
  }

  function strHash(s) {
    var h = 0;
    for (var i = 0; i < s.length; i++) h = ((h << 5) - h + s.charCodeAt(i)) | 0;
    return h;
  }

  function lcg(seed) {
    var s = seed | 0;
    return function() {
      s = (Math.imul(s, 1664525) + 1013904223) | 0;
      return ((s >>> 0) / 4294967296);
    };
  }

  function dailyShuffle(videos, slug) {
    var seed = (dayKey() ^ strHash(slug)) | 0;
    var r    = lcg(seed);
    var arr  = videos.slice();
    for (var i = arr.length - 1; i > 0; i--) {
      var j = Math.floor(r() * (i + 1));
      var t = arr[i]; arr[i] = arr[j]; arr[j] = t;
    }
    return arr;
  }

  function durationOf(v) { return Math.max(60, v.duration_s || 600); }

  function totalDuration(sched) {
    return sched.reduce(function(s, v) { return s + durationOf(v); }, 0);
  }

  function secondsSinceMidnight() {
    var n = new Date();
    return n.getHours() * 3600 + n.getMinutes() * 60 + n.getSeconds();
  }

  // For a channel + current local time, return the schedule + which video is
  // playing now and how many seconds into it we are.
  function nowPlaying(track) {
    var sched = dailyShuffle(track.videos, track.slug);
    var total = totalDuration(sched);
    var t     = secondsSinceMidnight() % total;
    var acc   = 0;
    for (var i = 0; i < sched.length; i++) {
      var d = durationOf(sched[i]);
      if (t < acc + d) {
        return {
          schedule:    sched,
          videoIndex:  i,
          offsetS:     Math.floor(t - acc),
          remainingS:  Math.floor(d - (t - acc)),
          startsAtMin: minutesOfDay(acc, total)
        };
      }
      acc += d;
    }
    return { schedule: sched, videoIndex: 0, offsetS: 0, remainingS: durationOf(sched[0]), startsAtMin: 0 };
  }

  // Wall-clock string for "this many seconds from now"
  function clockStr(secsFromNow) {
    var d = new Date(Date.now() + secsFromNow * 1000);
    var h = d.getHours(), m = d.getMinutes();
    return String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
  }

  function minutesOfDay(secs, total) {
    return Math.floor(((secsForToday() - secsForToday() % total) + secs) / 60);
  }
  function secsForToday() { return secondsSinceMidnight(); }

  function upcoming(track, count) {
    var info  = nowPlaying(track);
    var sched = info.schedule;
    var out   = [];
    var fromNow = info.remainingS;
    var i = (info.videoIndex + 1) % sched.length;
    while (out.length < count) {
      out.push({
        video: sched[i],
        startsAtClock: clockStr(fromNow),
        endsAtClock:   clockStr(fromNow + durationOf(sched[i]))
      });
      fromNow += durationOf(sched[i]);
      i = (i + 1) % sched.length;
    }
    return out;
  }

  // The shuffled schedule we're playing through right now for the active channel.
  // Recomputed on channel switch.
  var activeSchedule = [];

  function showHud() {
    footer.classList.add('hud-visible');
    clearTimeout(hudTimer);
    hudTimer = setTimeout(function() { footer.classList.remove('hud-visible'); }, 4000);
  }

  // ── Display ──────────────────────────────────────────────────────────────

  function updateDisplay() {
    var t = tracks[trackIdx];
    var v = activeSchedule[videoIdx] || t.videos[0];
    document.getElementById('chNum').textContent   = 'CH ' + String(trackIdx + 1).padStart(2, '0');
    document.getElementById('chEmoji').textContent = t.emoji;
    document.getElementById('chName').textContent  = t.title;
    document.getElementById('videoTitle').textContent = v.title;
    document.getElementById('videoPos').textContent   = (videoIdx + 1) + ' / ' + activeSchedule.length;
    document.getElementById('videoNote').textContent  = v.note || '';
    document.querySelectorAll('.guide-ch').forEach(function(el, i) {
      el.classList.toggle('active', i === trackIdx);
    });
  }

  function showGuide() {
    document.getElementById('guide').classList.add('visible');
    clearTimeout(guideTimer);
    guideTimer = setTimeout(function() {
      document.getElementById('guide').classList.remove('visible');
    }, 3000);
  }

  // ── Navigation ───────────────────────────────────────────────────────────

  function loadVideoAt(startSeconds) {
    if (!player) return;
    var v = activeSchedule[videoIdx];
    if (!v) return;
    player.loadVideoById({ videoId: v.youtube_id, startSeconds: Math.max(0, Math.floor(startSeconds || 0)) });
  }

  // Tune to a channel — picks the video that should be playing right now and
  // jumps to the correct offset, like switching channels on a real TV.
  window.selectChannel = function(idx) {
    trackIdx = idx;
    var info = nowPlaying(tracks[idx]);
    activeSchedule = info.schedule;
    videoIdx = info.videoIndex;
    loadVideoAt(info.offsetS);
    updateDisplay();
    showGuide();
    savePosition();
  };

  function changeChannel(delta) {
    selectChannel((trackIdx + delta + tracks.length) % tracks.length);
  }

  // Manual skip — moves through the daily-shuffled schedule, not the original
  // track order. New video starts from 0.
  function advanceVideo(delta) {
    if (!activeSchedule.length) return;
    videoIdx = (videoIdx + delta + activeSchedule.length) % activeSchedule.length;
    loadVideoAt(0);
    updateDisplay();
    savePosition();
  }

  function togglePlayPause() {
    if (!player) return;
    var state = player.getPlayerState();
    if (state === YT.PlayerState.PLAYING) {
      player.pauseVideo();
    } else {
      player.playVideo();
    }
  }

  function handleNav(dir) {
    if (isGuideOpen()) {
      switch (dir) {
        case 'up':     guideMove(-1);                                    break;
        case 'down':   guideMove(1);                                     break;
        case 'select': selectChannel(guideHighlight); closeTvGuide();    break;
        case 'back':   closeTvGuide();                                   break;
      }
      return;
    }
    showHud();
    switch (dir) {
      case 'up':     changeChannel(-1);    break;
      case 'down':   changeChannel(1);     break;
      case 'left':   advanceVideo(-1);     break;
      case 'right':  advanceVideo(1);      break;
      case 'select': togglePlayPause();    break;
      case 'back':   window.location.href = '/'; break;
    }
  }

  document.addEventListener('keydown', function(e) {
    // Guide-open keys take precedence
    if (isGuideOpen()) {
      switch (e.key) {
        case 'g': case 'G':
        case 'Escape':
          e.preventDefault(); closeTvGuide();                            return;
        case 'ArrowUp':
          e.preventDefault(); guideMove(-1);                             return;
        case 'ArrowDown':
          e.preventDefault(); guideMove(1);                              return;
        case 'Enter': case ' ':
          e.preventDefault(); selectChannel(guideHighlight); closeTvGuide(); return;
      }
      return;
    }
    showHud();
    switch (e.key) {
      case 'ArrowUp':                      e.preventDefault(); changeChannel(-1); break;
      case 'ArrowDown':                    e.preventDefault(); changeChannel(1);  break;
      case 'ArrowLeft':                    e.preventDefault(); advanceVideo(-1);  break;
      case 'ArrowRight':                   e.preventDefault(); advanceVideo(1);   break;
      case 'Enter': case ' ':              e.preventDefault(); togglePlayPause(); break;
      case 'g': case 'G':                  e.preventDefault(); openTvGuide();     break;
      case 'Escape': case 'Backspace':     window.location.href = '/';            break;
    }
  });

  // ── TV Guide overlay ─────────────────────────────────────────────────────

  function isGuideOpen() {
    return document.getElementById('tvGuide').classList.contains('visible');
  }

  function openTvGuide() {
    guideHighlight = trackIdx;
    renderTvGuide();
    document.getElementById('tvGuide').classList.add('visible');
    document.getElementById('tvGuide').setAttribute('aria-hidden', 'false');
    if (clockTimer) clearInterval(clockTimer);
    clockTimer = setInterval(renderTvGuide, 30000);  // refresh every 30s
  }

  function closeTvGuide() {
    document.getElementById('tvGuide').classList.remove('visible');
    document.getElementById('tvGuide').setAttribute('aria-hidden', 'true');
    if (clockTimer) { clearInterval(clockTimer); clockTimer = null; }
  }

  function guideMove(delta) {
    guideHighlight = (guideHighlight + delta + tracks.length) % tracks.length;
    document.querySelectorAll('.tv-guide-row').forEach(function(el, i) {
      el.classList.toggle('active', i === guideHighlight);
    });
    var el = document.querySelectorAll('.tv-guide-row')[guideHighlight];
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function escapeHtml(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderTvGuide() {
    var clockEl = document.getElementById('tvGuideClock');
    if (clockEl) clockEl.textContent = clockStr(0);

    var rowsEl = document.getElementById('tvGuideRows');
    rowsEl.innerHTML = '';
    tracks.forEach(function(track, i) {
      var info  = nowPlaying(track);
      var nowV  = info.schedule[info.videoIndex];
      var nowEnds = clockStr(info.remainingS);
      var slots = [{
        when: clockStr(0) + '–' + nowEnds,
        title: nowV.title,
        note: nowV.note || '',
        isNow: true
      }];
      upcoming(track, 3).forEach(function(u) {
        slots.push({
          when:  u.startsAtClock + '–' + u.endsAtClock,
          title: u.video.title,
          note:  u.video.note || '',
          isNow: false
        });
      });

      var slotsHtml = slots.map(function(s) {
        return '<div class="tv-guide-slot' + (s.isNow ? ' is-now' : '') + '">' +
                 '<div class="tv-guide-slot-time">' + escapeHtml(s.when) + '</div>' +
                 '<div class="tv-guide-slot-title">' + escapeHtml(s.title) + '</div>' +
                 (s.note ? '<div class="tv-guide-slot-note">' + escapeHtml(s.note) + '</div>' : '') +
               '</div>';
      }).join('');

      var row = document.createElement('div');
      row.className = 'tv-guide-row' + (i === guideHighlight ? ' active' : '');
      row.setAttribute('data-idx', i);
      row.innerHTML =
        '<div class="tv-guide-ch">' +
          '<div class="tv-guide-ch-num">CH ' + String(i + 1).padStart(2, '0') + '</div>' +
          '<div class="tv-guide-ch-row">' +
            '<span class="tv-guide-ch-emoji">' + track.emoji + '</span>' +
            '<span class="tv-guide-ch-name">' + escapeHtml(track.title) + '</span>' +
          '</div>' +
        '</div>' +
        '<div class="tv-guide-slots">' + slotsHtml + '</div>';
      row.addEventListener('click', function() {
        selectChannel(i);
        closeTvGuide();
      });
      rowsEl.appendChild(row);
    });
  }

  // ── Position persistence ─────────────────────────────────────────────────

  function savePosition() {
    var track = tracks[trackIdx];
    localStorage.setItem('ezaz_watch_track', track.slug);
    localStorage.setItem('ezaz_watch_video', videoIdx);
    var dt = localStorage.getItem('ezaz_device_token');
    if (dt) {
      clearTimeout(syncTimer);
      syncTimer = setTimeout(function() {
        fetch('/api/watch/position', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ device_token: dt, track_slug: track.slug, video_index: videoIdx })
        }).catch(function() {});
      }, 600);
    }
  }

  function applyPosition(slug, _ignored) {
    // We honour the saved channel choice (so kids return to the channel they
    // last watched) but always join at the schedule's current position — never
    // resume from a stale video index. That's the whole point of broadcast feel.
    var idx = tracks.findIndex(function(t) { return t.slug === slug; });
    if (idx < 0) return;
    selectChannel(idx);
  }

  function loadSavedPosition() {
    var dt = localStorage.getItem('ezaz_device_token');
    if (dt) {
      fetch('/api/watch/position?device_token=' + encodeURIComponent(dt))
        .then(function(r) { return r.ok ? r.json() : {}; })
        .then(function(d) { if (d.track_slug) applyPosition(d.track_slug, d.video_index); })
        .catch(function() {});
    } else {
      var slug = localStorage.getItem('ezaz_watch_track');
      var vi   = parseInt(localStorage.getItem('ezaz_watch_video') || '0', 10);
      if (slug) applyPosition(slug, isNaN(vi) ? 0 : vi);
    }
  }

  // ── YouTube player ────────────────────────────────────────────────────────

  function initPlayer() {
    // Initial schedule for the default channel
    var info = nowPlaying(tracks[trackIdx]);
    activeSchedule = info.schedule;
    videoIdx = info.videoIndex;

    player = new YT.Player('yt-player', {
      videoId: activeSchedule[videoIdx].youtube_id,
      playerVars: {
        autoplay:       1,
        controls:       0,
        rel:            0,
        modestbranding: 1,
        iv_load_policy: 3,
        fs:             0,
        playsinline:    1,
        start:          info.offsetS
      },
      events: {
        onReady: function(e) {
          if (info.offsetS > 0) { try { e.target.seekTo(info.offsetS, true); } catch (_) {} }
          e.target.playVideo();
          updateDisplay();
        },
        onStateChange: function(e) {
          if (e.data === YT.PlayerState.PLAYING) savePosition();
          if (e.data === YT.PlayerState.ENDED)   advanceVideo(1);
        },
        onError: function() {
          setTimeout(function() { advanceVideo(1); }, 1500);
        }
      }
    });
  }

  if (window._ytReady) {
    initPlayer();
  } else {
    window._ytCallbacks.push(initPlayer);
  }

  // ── ActionCable ───────────────────────────────────────────────────────────

  var consumer     = createConsumer();
  var subscription = consumer.subscriptions.create(
    { channel: 'TvRemoteChannel', token: token },
    {
      connected: function() {
        this.perform('set_state', { state: 'watch' });
      },
      received: function(data) {
        if (data.type === 'navigate' && data.nav_type !== 'release') {
          handleNav(data.direction);
        }
      }
    }
  );

  // ── Init ──────────────────────────────────────────────────────────────────

  if (!new URLSearchParams(location.search).get('t')) {
    history.replaceState({}, '', '/watch?t=' + token);
  }

  document.addEventListener('touchstart', showHud, { passive: true });

  updateDisplay();
  loadSavedPosition();
  showHud();
</script>

</body>
</html>
