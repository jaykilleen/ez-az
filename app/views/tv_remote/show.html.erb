<style>
  [hidden] { display: none !important; }

  .zone {
    display: flex; flex-direction: column;
    height: 100dvh;
    user-select: none; -webkit-user-select: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  /* ── Status bar ── */
  .zone-bar {
    padding: max(env(safe-area-inset-top), 14px) 20px 12px;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }
  .zone-brand { font-size: 14px; font-weight: 900; color: #00ffc8; letter-spacing: 0.1em; }
  .zone-conn  { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #445; }
  .zone-dot   { width: 8px; height: 8px; border-radius: 50%; background: #334; transition: background 0.3s; }
  .zone-dot.live { background: #00ffc8; box-shadow: 0 0 6px #00ffc8; }

  /* ── Main scrollable area ── */
  .zone-main {
    flex: 1; overflow-y: auto;
    display: flex; flex-direction: column;
  }
  .zone-content {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 24px 20px; gap: 20px; text-align: center;
  }

  /* claim */
  .claim-title { font-size: clamp(1.2rem, 5vw, 1.6rem); font-weight: 900; color: #fff; }
  .claim-hint  { font-size: 14px; color: #556; line-height: 1.6; }

  /* shelf */
  .zone-hint { font-size: 15px; color: #445; line-height: 1.7; }
  .zone-hint strong { color: #00ffc8; }

  /* lobby */
  .lobby-banner { display: flex; flex-direction: column; gap: 4px; }
  .lobby-game-name { font-size: clamp(1.4rem, 5vw, 1.8rem); font-weight: 900; color: #fff; }
  .lobby-room-code { font-size: 13px; color: #00ffc8; font-family: "Courier New", monospace; letter-spacing: 0.12em; }
  .lobby-join-form { display: flex; flex-direction: column; gap: 12px; width: 100%; max-width: 300px; }
  .zone-name-input {
    width: 100%; padding: 14px 18px;
    border-radius: 12px; background: rgba(255,255,255,0.08);
    border: 2px solid rgba(0,255,200,0.3); color: #fff;
    font-size: 20px; font-weight: 700; letter-spacing: 0.12em;
    text-align: center; outline: none;
    font-family: "Courier New", monospace;
    box-sizing: border-box;
  }
  .zone-name-input:focus { border-color: #00ffc8; }
  .zone-join-btn {
    padding: 16px; border-radius: 12px;
    background: #00ffc8; color: #0a0a12;
    font-size: 16px; font-weight: 900; border: none; cursor: pointer;
    letter-spacing: 0.04em; transition: opacity 0.15s;
  }
  .zone-join-btn:disabled { opacity: 0.5; }
  .zone-btn-ghost {
    background: transparent;
    color: #556;
    border: 2px solid rgba(255,255,255,0.08);
  }
  .zone-pin-input { letter-spacing: 0.3em; font-size: 24px; text-align: center; }
  .zone-join-error { color: #ff4757; font-size: 13px; }
  .lobby-divider {
    font-size: 11px; color: #334; letter-spacing: 0.1em; text-transform: uppercase;
    position: relative; width: 100%; max-width: 300px;
  }
  .lobby-divider::before, .lobby-divider::after {
    content: ''; position: absolute; top: 50%;
    width: 38%; height: 1px; background: rgba(255,255,255,0.08);
  }
  .lobby-divider::before { left: 0; }
  .lobby-divider::after  { right: 0; }

  /* waiting */
  .waiting-badge {
    width: 80px; height: 80px; border-radius: 50%;
    background: #334; display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 900; color: #fff;
    font-family: "Courier New", monospace; letter-spacing: 0.04em;
  }
  .waiting-msg { font-size: 14px; color: #8ab4c8; line-height: 1.6; }
  .waiting-players {
    width: 100%; max-width: 300px;
    background: rgba(255,255,255,0.04); border-radius: 12px;
    overflow: hidden;
  }
  .waiting-players-title {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: #445; padding: 10px 14px 6px;
  }
  .waiting-player-row {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 14px; border-top: 1px solid rgba(255,255,255,0.05);
  }
  .waiting-player-dot {
    width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
  }
  .waiting-player-name { font-size: 14px; font-weight: 700; color: #fff; flex: 1; }
  .waiting-player-you  { font-size: 11px; color: #00ffc8; letter-spacing: 0.06em; }
  .waiting-host-note {
    font-size: 12px; color: #445; line-height: 1.5;
    padding: 0 4px;
  }

  /* buzzer */
  .buzzer-content { gap: 10px; justify-content: flex-start; padding-top: 14px; }
  .buzzer-info { font-size: 13px; color: #8ab4c8; font-family: "Courier New", monospace; letter-spacing: 0.08em; }

  /* phone reading state */
  .phone-reading { display: flex; flex-direction: column; align-items: center; gap: 10px; width: 100%; }
  .phone-category {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: #00ffc8; background: rgba(0,255,200,0.12); border: 1px solid rgba(0,255,200,0.3);
    padding: 0.3em 0.9em; border-radius: 2em;
  }
  .phone-question {
    font-size: clamp(1rem, 4vw, 1.25rem); font-weight: 700; color: #fff;
    line-height: 1.45; text-align: center;
  }
  .phone-reading-hint { font-size: 13px; color: #556; margin-top: 4px; }
  .phone-timer {
    font-size: clamp(2.5rem, 12vw, 4rem); font-weight: 900;
    font-family: "Courier New", monospace; color: var(--buzz-color, #00ffc8);
    line-height: 1;
  }

  /* phone answering state */
  .phone-answering { display: flex; flex-direction: column; align-items: center; gap: 12px; width: 100%; }
  .buzz-answers {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px; width: 100%; max-width: 460px;
  }
  .answer-btn {
    padding: 14px 10px; border-radius: 12px;
    background: rgba(255,255,255,0.08); border: 2px solid rgba(255,255,255,0.15);
    color: #fff; font-size: clamp(0.85rem, 3.5vw, 1.05rem); font-weight: 700;
    text-align: center; cursor: pointer; line-height: 1.3; touch-action: manipulation;
    transition: background 0.08s; font-family: inherit;
  }
  .answer-btn:active { background: rgba(255,255,255,0.2); }
  .answer-btn:disabled { opacity: 0.35; }
  .answer-btn .aletter {
    display: block; font-size: 0.75em; color: rgba(255,255,255,0.45);
    margin-bottom: 4px; font-family: "Courier New", monospace;
  }
  .phone-ans-timer { font-size: clamp(1.5rem, 7vw, 2.5rem); }

  /* phone locked state */
  .phone-locked { display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .phone-locked-icon { font-size: clamp(3rem, 14vw, 5rem); color: #00ffc8; line-height: 1; }
  .phone-locked-msg { font-size: 15px; color: #8ab4c8; text-align: center; }

  /* phone result state */
  .phone-result { display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .phone-result-icon { font-size: clamp(3rem, 16vw, 6rem); font-weight: 900; line-height: 1; }
  .phone-result-msg { font-size: clamp(1rem, 4vw, 1.3rem); font-weight: 700; color: #fff; text-align: center; line-height: 1.4; }

  /* ── Spotlight phone states ── */
  .spot-banner {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 14px; border-radius: 10px;
    background: rgba(255,215,0,0.1); border: 1px solid rgba(255,215,0,0.3);
    font-size: 13px; color: #ffd700; font-weight: 700;
    width: 100%; max-width: 340px; box-sizing: border-box;
  }
  .spot-banner.is-me {
    background: rgba(255,215,0,0.18); border-color: #ffd700;
    color: #fff;
  }
  .spot-banner-icon { font-size: 18px; line-height: 1; }
  .spot-banner-text { flex: 1; line-height: 1.3; }
  .spot-banner-text b { color: #ffd700; }
  .spot-banner.is-me .spot-banner-text b { color: #fff; }

  .spot-question {
    font-size: clamp(1rem, 4vw, 1.2rem); font-weight: 700; color: #fff;
    line-height: 1.45; text-align: center;
    width: 100%; max-width: 360px;
  }
  .spot-prompt {
    font-size: 14px; color: #8ab4c8; line-height: 1.5; text-align: center;
    width: 100%; max-width: 340px;
  }
  .spot-prompt b { color: #fff; }

  .spot-input-wrap {
    display: flex; flex-direction: column; gap: 10px;
    width: 100%; max-width: 360px;
  }
  .spot-input {
    width: 100%; padding: 14px 16px; box-sizing: border-box;
    border-radius: 12px; background: rgba(255,255,255,0.08);
    border: 2px solid rgba(255,215,0,0.35); color: #fff;
    font-size: 17px; font-weight: 600; outline: none;
    font-family: inherit;
  }
  .spot-input:focus { border-color: #ffd700; }
  .spot-input.is-spotlight { border-color: #ffd700; background: rgba(255,215,0,0.08); }

  .spot-submit-btn {
    padding: 14px; border-radius: 12px;
    background: #ffd700; color: #0a0a12;
    font-size: 16px; font-weight: 900; border: none; cursor: pointer;
    letter-spacing: 0.04em; transition: opacity 0.15s;
  }
  .spot-submit-btn:disabled { opacity: 0.4; }

  .spot-pick-list {
    display: flex; flex-direction: column; gap: 10px;
    width: 100%; max-width: 360px;
  }
  .spot-pick-btn {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px; border-radius: 12px;
    background: rgba(255,255,255,0.06);
    border: 2px solid var(--pick-color, rgba(255,255,255,0.15));
    color: #fff; font-size: 15px; font-weight: 600;
    text-align: left; cursor: pointer; line-height: 1.4;
    font-family: inherit; transition: background 0.1s, transform 0.1s;
    width: 100%; box-sizing: border-box;
  }
  .spot-pick-btn:active { transform: scale(0.98); background: rgba(255,255,255,0.12); }
  .spot-pick-btn:disabled { opacity: 0.4; }
  .spot-pick-dot {
    width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    margin-top: 6px;
  }
  .spot-pick-name {
    font-size: 12px; font-weight: 800; letter-spacing: 0.06em;
    margin-bottom: 4px; opacity: 0.7;
  }

  .spot-status-line {
    font-size: 13px; color: #8ab4c8; text-align: center; line-height: 1.5;
  }
  .spot-status-line b { color: #ffd700; }

  /* ── Treasure Hunt phone states ── */
  .th-banner {
    display: flex; flex-direction: column; align-items: stretch; gap: 4px;
    padding: 10px 14px; border-radius: 10px;
    background: rgba(255,215,0,0.1); border: 1px solid rgba(255,215,0,0.3);
    width: 100%; max-width: 360px; box-sizing: border-box;
  }
  .th-banner-round {
    font-size: 11px; color: #ffd700; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  }
  .th-banner-label {
    font-size: 17px; font-weight: 900; color: #fff; line-height: 1.2;
    letter-spacing: 0.04em;
  }
  .th-banner-hint {
    font-size: 13px; color: #ccc; line-height: 1.4;
  }

  .th-status-line {
    font-size: 13px; color: #8ab4c8; text-align: center; line-height: 1.5;
  }
  .th-status-line b { color: #ffd700; }

  /* hand grid */
  .th-hand {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
    width: 100%; max-width: 340px;
  }
  .th-hand.is-locked .th-card-btn { pointer-events: none; opacity: 0.55; }

  .th-card-btn {
    aspect-ratio: 2 / 3;
    border-radius: 10px;
    background: linear-gradient(160deg, #fff, #ddd);
    border: 2px solid var(--card-border, #888);
    color: #222;
    display: flex; flex-direction: column; align-items: center; justify-content: space-between;
    padding: 6px 5px;
    cursor: pointer; touch-action: manipulation;
    font-family: "Courier New", monospace;
    transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
    position: relative;
    -webkit-tap-highlight-color: transparent;
  }
  .th-card-btn:active { transform: scale(0.96); }
  .th-card-btn.is-selected {
    box-shadow: 0 0 0 3px #ffd700, 0 0 14px rgba(255,215,0,0.5);
    transform: translateY(-3px) scale(1.02);
  }
  .th-card-btn[data-colour="red"]    { --card-border: #ff4757; background: linear-gradient(160deg, #fff, #ffd9dc); color: #6b0e1a; }
  .th-card-btn[data-colour="blue"]   { --card-border: #3742fa; background: linear-gradient(160deg, #fff, #d6dcff); color: #161a4a; }
  .th-card-btn[data-colour="green"]  { --card-border: #2ed573; background: linear-gradient(160deg, #fff, #d4f7df); color: #0d4e22; }
  .th-card-btn[data-colour="yellow"] { --card-border: #ffc312; background: linear-gradient(160deg, #fff, #fff0c2); color: #5e4500; }

  .th-card-corner {
    align-self: flex-start;
    font-size: 13px; font-weight: 900; line-height: 1;
    display: flex; flex-direction: column; align-items: flex-start;
  }
  .th-card-corner-suit { font-size: 14px; line-height: 1; }
  .th-card-centre {
    font-size: 26px; font-weight: 900; line-height: 1;
  }
  .th-card-corner-bottom {
    align-self: flex-end; transform: rotate(180deg);
    font-size: 13px; font-weight: 900; line-height: 1;
    display: flex; flex-direction: column; align-items: flex-start;
  }

  .th-locked-card {
    width: 96px; height: 144px; border-radius: 12px;
    border: 3px solid #ffd700; box-shadow: 0 0 18px rgba(255,215,0,0.4);
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 8px 7px;
    font-family: "Courier New", monospace;
  }
  .th-locked-card[data-colour="red"]    { background: linear-gradient(160deg, #fff, #ffd9dc); color: #6b0e1a; }
  .th-locked-card[data-colour="blue"]   { background: linear-gradient(160deg, #fff, #d6dcff); color: #161a4a; }
  .th-locked-card[data-colour="green"]  { background: linear-gradient(160deg, #fff, #d4f7df); color: #0d4e22; }
  .th-locked-card[data-colour="yellow"] { background: linear-gradient(160deg, #fff, #fff0c2); color: #5e4500; }

  .th-confirm-btn {
    width: 100%; max-width: 340px;
    padding: 14px; border-radius: 12px;
    background: #ffd700; color: #0a0a12;
    font-size: 16px; font-weight: 900; border: none; cursor: pointer;
    letter-spacing: 0.04em; transition: opacity 0.15s;
  }
  .th-confirm-btn:disabled { opacity: 0.35; cursor: not-allowed; }

  .back-to-store {
    display: block; padding: 14px 24px; border-radius: 12px;
    background: rgba(255,255,255,0.06); border: 2px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.55); font-size: 14px; font-weight: 700;
    text-decoration: none; margin-top: 8px;
  }

  /* ── Hacker Pro phone states ── */
  .hk-zone {
    color: #00ff66;
    font-family: "Courier New", monospace;
    text-shadow: 0 0 4px rgba(0, 255, 102, 0.4);
  }
  .hk-zone-banner {
    display: flex; flex-direction: column; gap: 4px;
    padding: 10px 14px;
    border: 1px solid rgba(0, 255, 102, 0.3);
    background: rgba(0, 255, 102, 0.06);
    width: 100%; max-width: 360px; box-sizing: border-box;
  }
  .hk-zone-banner-label {
    font-size: 11px; color: #ffb300; letter-spacing: 0.15em; text-transform: uppercase;
    font-weight: 700;
  }
  .hk-zone-banner-progress {
    font-size: 13px; color: #00ff66;
  }
  .hk-zone-banner-progress b { color: #ffb300; }

  .hk-zone-slots {
    display: flex; gap: 4px; flex-wrap: wrap; justify-content: center;
    width: 100%; max-width: 360px;
    padding: 4px 0;
  }
  .hk-zone-slot {
    flex: 1 1 28px;
    max-width: 36px;
    aspect-ratio: 2 / 3;
    border: 2px solid #008833;
    background: rgba(0, 255, 102, 0.04);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 900;
    color: #00ff66;
  }
  .hk-zone-slot.is-locked {
    border-color: #00ff66;
    background: rgba(0, 255, 102, 0.16);
    box-shadow: 0 0 6px rgba(0, 255, 102, 0.3);
  }
  .hk-zone-slot.is-cursor {
    border-color: #ffb300;
    box-shadow: 0 0 0 2px rgba(255, 179, 0, 0.5);
    animation: hk-zone-pulse 0.9s ease-in-out infinite;
  }
  @keyframes hk-zone-pulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(255, 179, 0, 0.5); }
    50%      { box-shadow: 0 0 0 4px rgba(255, 179, 0, 0.85); }
  }

  .hk-zone-char-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    margin-top: 4px;
  }
  .hk-zone-char-label {
    font-size: 10px; color: #008833; letter-spacing: 0.15em; text-transform: uppercase;
  }
  .hk-zone-char-row {
    display: flex; align-items: stretch; gap: 8px;
  }
  .hk-zone-char-btn {
    width: 56px; height: 72px;
    border: 2px solid rgba(0, 255, 102, 0.35);
    background: rgba(0, 255, 102, 0.06);
    color: #00ff66; font-size: 30px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; touch-action: manipulation;
    font-family: inherit;
  }
  .hk-zone-char-btn:active { background: rgba(0, 255, 102, 0.18); }
  .hk-zone-char-display {
    width: 96px; height: 72px;
    border: 3px solid #ffb300;
    background: rgba(255, 179, 0, 0.08);
    color: #ffb300;
    font-size: 44px; font-weight: 900;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 14px rgba(255, 179, 0, 0.3);
  }

  .hk-zone-cursor-row {
    display: flex; gap: 8px; width: 100%; max-width: 360px;
  }
  .hk-zone-cursor-btn {
    flex: 1; padding: 14px 8px;
    border: 2px solid rgba(0, 255, 102, 0.35);
    background: rgba(0, 255, 102, 0.04);
    color: #00ff66; font-size: 16px; font-weight: 900;
    border-radius: 10px; cursor: pointer; touch-action: manipulation;
    font-family: inherit; letter-spacing: 0.04em;
  }
  .hk-zone-cursor-btn:active { background: rgba(0, 255, 102, 0.16); }
  .hk-zone-cursor-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  .hk-zone-attack-btn {
    width: 100%; max-width: 360px;
    padding: 18px;
    background: rgba(255, 45, 85, 0.18);
    border: 3px solid #ff2d55;
    color: #ff2d55;
    font-size: 18px; font-weight: 900;
    letter-spacing: 0.12em;
    border-radius: 12px; cursor: pointer; touch-action: manipulation;
    font-family: inherit;
    box-shadow: 0 0 16px rgba(255, 45, 85, 0.25);
  }
  .hk-zone-attack-btn:active { background: rgba(255, 45, 85, 0.4); }
  .hk-zone-attack-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .hk-zone-feedback {
    font-size: 13px; color: #008833; text-align: center; min-height: 16px;
    letter-spacing: 0.06em;
  }
  .hk-zone-feedback.is-hit  { color: #00ff66; font-weight: 700; }
  .hk-zone-feedback.is-miss { color: #ff2d55; font-weight: 700; }

  .hk-zone-won {
    display: flex; flex-direction: column; align-items: center; gap: 12px;
    color: #00ff66;
  }
  .hk-zone-won-icon { font-size: 56px; line-height: 1; }
  .hk-zone-won-msg { font-size: 16px; text-align: center; line-height: 1.5; }

  /* ── Boomerang Brawl phone states ── */
  .br-zone {
    color: #fff;
    font-family: 'Inter', sans-serif;
  }
  .br-zone-content {
    gap: 14px;
    justify-content: space-between;
    padding-top: 14px;
  }
  .br-zone-banner {
    width: 100%; max-width: 360px; box-sizing: border-box;
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; border-radius: 12px;
    background: rgba(255, 136, 0, 0.08);
    border: 1px solid rgba(255, 136, 0, 0.3);
  }
  .br-zone-badge {
    display: flex; align-items: center; gap: 8px;
    font-size: 14px; font-weight: 800;
  }
  .br-zone-dot {
    width: 14px; height: 14px; border-radius: 50%;
    box-shadow: 0 0 6px currentColor;
  }
  .br-zone-status {
    font-size: 12px; color: #c8b48a;
    letter-spacing: 0.05em;
  }
  .br-zone-status.is-out { color: #ff4757; font-weight: 700; }

  .br-zone-rounds {
    display: flex; align-items: center; gap: 10px;
    font-size: 12px; color: #889;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  .br-zone-rounds-pips { display: flex; gap: 4px; }
  .br-zone-rounds-pip {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.15);
  }
  .br-zone-rounds-pip.is-on { background: var(--my-color, #00ffc8); }

  .br-zone-controls {
    width: 100%;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 16px;
    padding: 12px 8px max(env(safe-area-inset-bottom, 0px), 12px);
  }
  .br-zone-dpad {
    display: grid;
    grid-template-columns: 64px 64px 64px;
    grid-template-rows: 64px 64px 64px;
    gap: 6px; justify-self: center;
  }
  .br-zone-dpad-btn {
    border-radius: 14px; background: rgba(255, 136, 0, 0.1);
    border: 2px solid rgba(255, 136, 0, 0.35);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; color: #ff8800;
    user-select: none; touch-action: none;
    -webkit-user-select: none; -webkit-tap-highlight-color: transparent;
  }
  .br-zone-dpad-btn.pressed { background: rgba(255, 136, 0, 0.4); border-color: #ff8800; }
  .br-zone-dpad-empty { background: none !important; border: none !important; }
  .br-zone-attack {
    width: 130px; height: 130px; border-radius: 50%;
    justify-self: center;
    background: rgba(255, 71, 87, 0.18);
    border: 4px solid rgba(255, 71, 87, 0.6);
    color: #ff4757; font-weight: 900; font-size: 18px;
    letter-spacing: 0.1em;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; touch-action: none;
    -webkit-user-select: none; user-select: none;
    -webkit-tap-highlight-color: transparent;
    box-shadow: 0 0 16px rgba(255, 71, 87, 0.3);
  }
  .br-zone-attack.pressed { background: rgba(255, 71, 87, 0.5); border-color: #ff4757; }
  .br-zone-attack.is-cooldown { opacity: 0.4; }
  .br-zone-attack.is-out { opacity: 0.25; pointer-events: none; }

  .br-zone-out-msg {
    font-size: 14px; color: #ff4757; font-weight: 700;
    text-align: center; line-height: 1.5;
  }

  /* watching */
  .watching-hint { color: #8ab4c8; }

  /* disconnected */
  .disconnected-title { font-size: 20px; color: #fff; font-weight: 700; }
  .disconnected-msg   { font-size: 14px; color: #556; line-height: 1.6; }

  /* ── Party tab bar ── */
  .zone-tabs {
    flex-shrink: 0; display: flex;
    border-top: 1px solid rgba(255,255,255,0.08);
    background: rgba(0,0,0,0.3);
  }
  .zone-tab {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    gap: 3px; padding: 10px 6px max(env(safe-area-inset-bottom, 0px), 10px);
    background: none; border: none; color: #445;
    font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; cursor: pointer;
    transition: color 0.15s, background 0.15s;
    font-family: inherit;
  }
  .zone-tab .tab-icon { font-size: 22px; line-height: 1; }
  .zone-tab.active { color: #00ffc8; background: rgba(0,255,200,0.06); }
  .zone-tab:active { background: rgba(255,255,255,0.05); }
  .zone-tab-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #ff4757; position: absolute; top: 8px; right: calc(50% - 18px);
  }

  /* ── Options panel (replaces main when Options tab active) ── */
  .zone-options-panel {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 16px; padding: 24px 20px;
  }
  .options-exit-btn {
    display: block; width: 100%; max-width: 280px;
    padding: 16px; border-radius: 12px; text-align: center;
    background: rgba(255,71,87,0.12); border: 2px solid rgba(255,71,87,0.35);
    color: #ff4757; font-size: 15px; font-weight: 700;
    text-decoration: none; transition: background 0.15s;
  }
  .options-exit-btn:active { background: rgba(255,71,87,0.25); }
  .options-hint { font-size: 12px; color: #334; text-align: center; line-height: 1.6; }

  /* ── D-pad ── */
  .zone-dpad {
    flex-shrink: 0; display: flex; flex-direction: column;
    align-items: center; gap: 18px;
    padding: 18px 20px max(env(safe-area-inset-bottom), 20px);
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .dpad {
    display: grid;
    grid-template-columns: 72px 72px 72px;
    grid-template-rows: 72px 72px 72px;
    gap: 8px;
  }
  .dpad-btn {
    border-radius: 14px; background: rgba(0,255,200,0.08);
    border: 2px solid rgba(0,255,200,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; color: #00ffc8; cursor: pointer;
    transition: background 0.08s, border-color 0.08s;
  }
  .dpad-btn.pressed, .dpad-btn:active {
    background: rgba(0,255,200,0.25); border-color: #00ffc8;
  }
  .dpad-center {
    background: rgba(0,255,200,0.12); border-color: rgba(0,255,200,0.4);
    font-size: 13px; font-weight: 800; letter-spacing: 0.06em;
  }
  .dpad-center.pressed { background: #00ffc8; color: #0a0a12; }
  .dpad-empty { background: none !important; border: none !important; pointer-events: none; }
  .back-btn {
    padding: 12px 28px; border-radius: 10px;
    background: rgba(255,255,255,0.05); border: 2px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.45); font-size: 13px; font-weight: 700;
    letter-spacing: 0.06em; cursor: pointer;
  }
  .back-btn:active { background: rgba(255,255,255,0.1); }
  .fire-btn {
    width: 88px; height: 88px; border-radius: 50%;
    background: rgba(255, 71, 87, 0.15); border: 3px solid rgba(255, 71, 87, 0.5);
    color: #ff4757; font-size: 13px; font-weight: 900; letter-spacing: 0.06em;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; touch-action: none; -webkit-user-select: none; user-select: none;
    transition: background 0.08s, border-color 0.08s;
  }
  .fire-btn.pressed { background: rgba(255, 71, 87, 0.4); border-color: #ff4757; }
  .zone-game-controls {
    display: flex; align-items: center; gap: 28px;
  }
</style>

<div class="zone">

  <div class="zone-bar">
    <span class="zone-brand">EZ-AZ</span>
    <div class="zone-conn">
      <span class="zone-dot" id="zone-dot"></span>
      <span id="zone-status">Connecting...</span>
    </div>
  </div>

  <div class="zone-main">

    <!-- claim: first visit, pick a name -->
    <div class="zone-content" data-screen="claim" hidden>

      <!-- Step 1: name entry -->
      <div id="claim-name-step">
        <div class="claim-title">What's your name?</div>
        <div class="claim-hint">We'll save your spot if you disconnect.</div>
        <div class="lobby-join-form">
          <input class="zone-name-input" id="claim-input" type="text"
                 placeholder="YOUR NAME" maxlength="12"
                 autocapitalize="characters" autocomplete="off" spellcheck="false">
          <button class="zone-join-btn" id="claim-btn">Let's Go &rarr;</button>
          <div class="zone-join-error" id="claim-error" hidden></div>
        </div>
      </div>

      <!-- Step 2a: set a PIN after claiming a new name -->
      <div id="claim-pin-setup-step" hidden>
        <div class="claim-title">Set a PIN</div>
        <div class="claim-hint">4 digits — lets you log in from any device.</div>
        <div class="lobby-join-form">
          <input class="zone-name-input zone-pin-input" id="pin-setup-input"
                 type="tel" maxlength="4" pattern="\d{4}" placeholder="••••"
                 autocomplete="new-password">
          <button class="zone-join-btn" id="pin-setup-btn">Save PIN &rarr;</button>
          <button class="zone-join-btn zone-btn-ghost" id="pin-setup-skip-btn">Skip for now</button>
          <div class="zone-join-error" id="pin-setup-error" hidden></div>
        </div>
      </div>

      <!-- Step 2b: PIN login when name is already taken -->
      <div id="claim-pin-login-step" hidden>
        <div class="claim-title" id="pin-login-title">Welcome back!</div>
        <div class="claim-hint">Enter your 4-digit PIN to log in.</div>
        <div class="lobby-join-form">
          <input class="zone-name-input zone-pin-input" id="pin-login-input"
                 type="tel" maxlength="4" pattern="\d{4}" placeholder="••••"
                 autocomplete="current-password">
          <button class="zone-join-btn" id="pin-login-btn">Log In &rarr;</button>
          <button class="zone-join-btn zone-btn-ghost" id="pin-back-btn">&larr; Different name</button>
          <div class="zone-join-error" id="pin-login-error" hidden></div>
        </div>
      </div>

    </div>

    <!-- shelf: browsing the game shelf -->
    <div class="zone-content" data-screen="shelf">
      <div class="zone-hint">
        Use the arrows to browse games.<br>
        Press <strong>OK</strong> to launch.
      </div>
    </div>

    <!-- lobby: a game lobby is open on TV -->
    <div class="zone-content" data-screen="lobby" hidden>
      <div class="lobby-banner">
        <div class="lobby-game-name" id="lobby-game-name">Family Trivia</div>
        <div class="lobby-room-code" id="lobby-room-code">Room …</div>
      </div>
      <div class="lobby-join-form">
        <input class="zone-name-input" id="name-input" type="text"
               placeholder="YOUR NAME" maxlength="12"
               autocapitalize="characters" autocomplete="off" spellcheck="false">
        <button class="zone-join-btn" id="join-btn">Join Game &rarr;</button>
        <div class="zone-join-error" id="join-error" hidden></div>
      </div>
      <div class="lobby-divider">or use as remote</div>
    </div>

    <!-- waiting: joined, waiting for host to start -->
    <div class="zone-content" data-screen="waiting" hidden>
      <div class="waiting-badge" id="waiting-badge">P1</div>
      <div class="waiting-msg">You're in! Waiting to start&hellip;</div>
      <div class="waiting-players" id="waiting-players">
        <div class="waiting-players-title">In the room</div>
      </div>
      <div class="waiting-host-note">
        The person holding the D-pad controls<br>when the game starts.
      </div>
      <button id="leave-game-btn" class="options-exit-btn" style="margin-top: 12px;">← Leave Game</button>
    </div>

    <!-- buzzer: trivia game in progress, joined -->
    <div class="zone-content buzzer-content" data-screen="buzzer" hidden>
      <div class="buzzer-info" id="buzzer-info">P1</div>

      <!-- reading: question shown, get ready -->
      <div id="phone-reading" class="phone-reading">
        <div class="phone-category" id="phone-category"></div>
        <div class="phone-question" id="phone-question"></div>
        <div class="phone-reading-hint">Get ready to answer!</div>
        <div class="phone-timer" id="phone-read-timer"></div>
      </div>

      <!-- answering: pick your option -->
      <div id="phone-answering" class="phone-answering" hidden>
        <div class="buzz-answers" id="buzz-answers"></div>
        <div class="phone-timer phone-ans-timer" id="phone-ans-timer"></div>
      </div>

      <!-- locked: answered, awaiting reveal -->
      <div id="phone-locked" class="phone-locked" hidden>
        <div class="phone-locked-icon">&#10003;</div>
        <div class="phone-locked-msg">Locked in!<br>Waiting for reveal…</div>
      </div>

      <!-- result: after reveal -->
      <div id="phone-result" class="phone-result" hidden>
        <div class="phone-result-icon" id="phone-result-icon"></div>
        <div class="phone-result-msg" id="phone-result-msg"></div>
      </div>
    </div>

    <!-- spotlight: spotlight game in progress, joined -->
    <div class="zone-content buzzer-content" data-screen="spotlight" hidden>
      <div class="buzzer-info" id="spot-info">P1</div>

      <!-- spotlight banner: shows who's in the spotlight this round -->
      <div class="spot-banner" id="spot-banner">
        <div class="spot-banner-icon">🌟</div>
        <div class="spot-banner-text">
          <b id="spot-banner-name">—</b> is in the spotlight
        </div>
      </div>

      <!-- reading: question shown, get ready -->
      <div id="spot-reading-state">
        <div class="spot-question" id="spot-question"></div>
        <div class="spot-prompt" id="spot-reading-prompt">Get ready to type!</div>
      </div>

      <!-- typing: text input phase -->
      <div id="spot-typing-state" hidden>
        <div class="spot-question" id="spot-question-2"></div>
        <div class="spot-prompt" id="spot-typing-prompt"></div>
        <div class="spot-input-wrap">
          <input class="spot-input" id="spot-input" type="text"
                 maxlength="80" autocomplete="off" autocorrect="off" spellcheck="false">
          <button class="spot-submit-btn" id="spot-submit-btn">Lock it in →</button>
        </div>
      </div>

      <!-- locked: waiting for others or for picking -->
      <div id="spot-locked-state" class="phone-locked" hidden>
        <div class="phone-locked-icon">&#10003;</div>
        <div class="phone-locked-msg" id="spot-locked-msg">Locked in!<br>Waiting for others…</div>
      </div>

      <!-- picking: spotlight picks favourite -->
      <div id="spot-picking-state" hidden>
        <div class="spot-status-line" id="spot-picking-msg"></div>
        <div class="spot-pick-list" id="spot-pick-list"></div>
      </div>

      <!-- result: after reveal -->
      <div id="spot-result-state" class="phone-result" hidden>
        <div class="phone-result-icon" id="spot-result-icon"></div>
        <div class="phone-result-msg" id="spot-result-msg"></div>
      </div>
    </div>

    <!-- treasure: card game in progress, joined -->
    <div class="zone-content buzzer-content" data-screen="treasure" hidden>
      <div class="buzzer-info" id="th-info">P1</div>

      <div class="th-banner">
        <div class="th-banner-round" id="th-banner-round">Round 1 of 5</div>
        <div class="th-banner-label" id="th-banner-label">—</div>
        <div class="th-banner-hint" id="th-banner-hint">—</div>
      </div>

      <div class="th-status-line" id="th-status-line">Pick a card from your hand.</div>

      <!-- hand: tap to pick -->
      <div id="th-hand" class="th-hand"></div>

      <button class="th-confirm-btn" id="th-confirm-btn" disabled>Lock it in →</button>

      <!-- locked: showing the locked card -->
      <div id="th-locked-wrap" class="phone-locked" hidden>
        <div class="phone-locked-msg" id="th-locked-msg">Locked in!</div>
        <div class="th-locked-card" id="th-locked-card"></div>
      </div>

      <!-- result: after reveal -->
      <div id="th-result-wrap" class="phone-result" hidden>
        <div class="phone-result-icon" id="th-result-icon"></div>
        <div class="phone-result-msg" id="th-result-msg"></div>
      </div>
    </div>

    <!-- hacker: brute-force code game in progress, joined -->
    <div class="zone-content buzzer-content hk-zone" data-screen="hacker" hidden>
      <div class="buzzer-info" id="hk-info" style="color:#00ff66">P1</div>

      <div class="hk-zone-banner">
        <div class="hk-zone-banner-label" id="hk-zone-diff">DIFFICULTY —</div>
        <div class="hk-zone-banner-progress" id="hk-zone-progress">
          <b id="hk-zone-revealed">0</b> / <b id="hk-zone-total">0</b> slots cracked
          <span style="color:#008833;margin-left:8px">·</span>
          <b id="hk-zone-attempts">0</b> attempts
        </div>
      </div>

      <div class="hk-zone-slots" id="hk-zone-slots"></div>

      <div class="hk-zone-cursor-row">
        <button class="hk-zone-cursor-btn" id="hk-zone-prev" type="button">◀ SLOT</button>
        <button class="hk-zone-cursor-btn" id="hk-zone-next" type="button">SLOT ▶</button>
      </div>

      <div class="hk-zone-char-wrap">
        <div class="hk-zone-char-label">YOUR GUESS</div>
        <div class="hk-zone-char-row">
          <button class="hk-zone-char-btn" id="hk-zone-char-down" type="button">▼</button>
          <div class="hk-zone-char-display" id="hk-zone-char-display">0</div>
          <button class="hk-zone-char-btn" id="hk-zone-char-up" type="button">▲</button>
        </div>
      </div>

      <button class="hk-zone-attack-btn" id="hk-zone-attack" type="button">▶ ATTACK</button>

      <div class="hk-zone-feedback" id="hk-zone-feedback">&nbsp;</div>

      <!-- won: game over -->
      <div id="hk-zone-won-state" class="hk-zone-won" hidden>
        <div class="hk-zone-won-icon">✓</div>
        <div class="hk-zone-won-msg" id="hk-zone-won-msg">ACCESS GRANTED!<br>Check the TV.</div>
      </div>
    </div>

    <!-- boomerang: real-time arena, joined -->
    <div class="zone-content br-zone br-zone-content" data-screen="boomerang" hidden>
      <div class="br-zone-banner">
        <div class="br-zone-badge">
          <span class="br-zone-dot" id="br-zone-dot"></span>
          <span id="br-zone-name">P1</span>
          <span class="br-zone-status" id="br-zone-status">ALIVE</span>
        </div>
        <div class="br-zone-rounds">
          R<span id="br-zone-round">1</span>
          <div class="br-zone-rounds-pips" id="br-zone-rounds-pips"></div>
        </div>
      </div>

      <div id="br-zone-out-msg" class="br-zone-out-msg" hidden>
        You're out!<br>Wait for the next round…
      </div>

      <div class="br-zone-controls" id="br-zone-controls">
        <div class="br-zone-dpad">
          <div class="br-zone-dpad-empty"></div>
          <div class="br-zone-dpad-btn" data-br-dir="up">▲</div>
          <div class="br-zone-dpad-empty"></div>

          <div class="br-zone-dpad-btn" data-br-dir="left">◀</div>
          <div class="br-zone-dpad-empty"></div>
          <div class="br-zone-dpad-btn" data-br-dir="right">▶</div>

          <div class="br-zone-dpad-empty"></div>
          <div class="br-zone-dpad-btn" data-br-dir="down">▼</div>
          <div class="br-zone-dpad-empty"></div>
        </div>
        <div class="br-zone-attack" id="br-zone-attack">THROW</div>
      </div>
    </div>

    <!-- watching: game in progress, not joined -->
    <div class="zone-content" data-screen="watching" hidden>
      <div class="zone-hint watching-hint">
        Game in progress.<br>Use the remote to control.
      </div>
    </div>

    <!-- disconnected -->
    <div class="zone-content" data-screen="disconnected" hidden>
      <div class="disconnected-title">TV disconnected</div>
      <div class="disconnected-msg">Go back to the TV<br>and scan the QR code again.</div>
    </div>

  </div>

  <!-- Party tab bar — shown during game sessions -->
  <div class="zone-tabs" id="zone-tabs" hidden>
    <button class="zone-tab active" data-tab="game">
      <span class="tab-icon">🎮</span>Game
    </button>
    <button class="zone-tab" data-tab="remote" style="position:relative">
      <span class="tab-icon">🕹️</span>Remote
      <span class="zone-tab-dot" id="remote-dot" hidden></span>
    </button>
    <button class="zone-tab" data-tab="options">
      <span class="tab-icon">⚙️</span>Options
    </button>
  </div>

  <!-- Options panel content -->
  <div class="zone-options-panel" id="zone-options-panel" hidden>
    <a href="/" class="options-exit-btn">← Exit to Store</a>
    <div class="options-hint">You can also use the Remote tab<br>to control the TV D-pad.</div>
  </div>

  <!-- D-pad — shown when browsing non-game screens, or Remote tab active -->
  <div class="zone-dpad" id="zone-dpad" hidden>
    <div class="zone-game-controls">
      <div class="dpad">
        <div class="dpad-empty"></div>
        <div class="dpad-btn" data-dir="up">&#9650;</div>
        <div class="dpad-empty"></div>

        <div class="dpad-btn" data-dir="left">&#9664;</div>
        <div class="dpad-btn dpad-center" data-dir="select">OK</div>
        <div class="dpad-btn" data-dir="right">&#9654;</div>

        <div class="dpad-empty"></div>
        <div class="dpad-btn" data-dir="down">&#9660;</div>
        <div class="dpad-empty"></div>
      </div>
      <div class="fire-btn" id="fire-btn" data-dir="action" hidden>FIRE</div>
    </div>
    <button class="back-btn" data-dir="back">← BACK</button>
  </div>

</div>

<script type="module">
  import { createConsumer } from "<%= asset_path('actioncable.esm.js') %>";

  var token       = <%= @token.to_json.html_safe %>;
  var roomCode    = <%= @room_code.to_json.html_safe %>;
  var deviceToken = localStorage.getItem('ezaz_device_token') || '';
  var myUsername  = localStorage.getItem('ezaz_username') || '';

  // ── State ──────────────────────────────────────────────────────────
  var currentScreen    = 'disconnected';
  var mySlot           = null;
  var myColor          = null;
  var triviaChannel    = null;
  var spotlightChannel = null;
  var treasureChannel  = null;
  var hackerChannel    = null;
  var boomerangChannel = null;
  var roomChannel      = null;
  var remote           = null;
  var myAnswerIndex    = null;
  var phoneTimerInterval = null;
  var activeTab        = 'game';
  var letters          = ['A', 'B', 'C', 'D'];
  var gameSlug         = null;
  var spotState        = { phase: null, spotlightSlot: null };
  var DPAD_SCREENS     = new Set(['shelf', 'lobby', 'waiting', 'watching']);
  var SLOT_COLORS      = { 1: '#ff4757', 2: '#3742fa', 3: '#ffa502', 4: '#2ed573' };

  // ── Elements ────────────────────────────────────────────────────────
  var zoneDot   = document.getElementById('zone-dot');
  var zoneStatus = document.getElementById('zone-status');
  var zoneDpad  = document.getElementById('zone-dpad');
  var fireBtn   = document.getElementById('fire-btn');

  var claimInput      = document.getElementById('claim-input');
  var claimBtn        = document.getElementById('claim-btn');
  var claimError      = document.getElementById('claim-error');
  var claimNameStep   = document.getElementById('claim-name-step');
  var pinSetupStep    = document.getElementById('claim-pin-setup-step');
  var pinLoginStep    = document.getElementById('claim-pin-login-step');
  var pinSetupInput   = document.getElementById('pin-setup-input');
  var pinSetupBtn     = document.getElementById('pin-setup-btn');
  var pinSetupSkipBtn = document.getElementById('pin-setup-skip-btn');
  var pinSetupError   = document.getElementById('pin-setup-error');
  var pinLoginInput   = document.getElementById('pin-login-input');
  var pinLoginBtn     = document.getElementById('pin-login-btn');
  var pinLoginTitle   = document.getElementById('pin-login-title');
  var pinLoginError   = document.getElementById('pin-login-error');
  var pinBackBtn      = document.getElementById('pin-back-btn');

  var lobbyGameName = document.getElementById('lobby-game-name');
  var lobbyRoomCode = document.getElementById('lobby-room-code');
  var nameInput     = document.getElementById('name-input');
  var joinBtn       = document.getElementById('join-btn');
  var joinError     = document.getElementById('join-error');
  var waitingBadge    = document.getElementById('waiting-badge');
  var waitingPlayers  = document.getElementById('waiting-players');
  var leaveGameBtn    = document.getElementById('leave-game-btn');
  var buzzerInfo      = document.getElementById('buzzer-info');
  var zoneTabs        = document.getElementById('zone-tabs');
  var zoneOptionsPanel = document.getElementById('zone-options-panel');
  var remoteDot       = document.getElementById('remote-dot');

  // ── Screen switching ────────────────────────────────────────────────
  var PARTY_SCREENS  = new Set(['buzzer', 'spotlight', 'treasure', 'hacker', 'boomerang']);
  var TABBED_SCREENS = new Set(['shelf', 'lobby', 'waiting', 'watching', 'buzzer', 'spotlight', 'treasure', 'hacker', 'boomerang']);

  function showScreen(name) {
    currentScreen = name;
    var isParty = PARTY_SCREENS.has(name);
    var isDpad  = DPAD_SCREENS.has(name);

    document.querySelectorAll('.zone-content').forEach(function(el) {
      el.hidden = el.dataset.screen !== name;
    });

    zoneTabs.hidden = !TABBED_SCREENS.has(name);

    if (isParty) {
      applyTab(activeTab);
    } else {
      zoneDpad.hidden = !isDpad;
      zoneOptionsPanel.hidden = true;
      document.querySelectorAll('.zone-tab').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.tab === 'game');
      });
      activeTab = 'game';
    }
  }

  function applyTab(tab) {
    activeTab = tab;
    document.querySelectorAll('.zone-tab').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.tab === tab);
    });

    if (PARTY_SCREENS.has(currentScreen)) {
      document.querySelectorAll('.zone-content').forEach(function(el) {
        el.hidden = el.dataset.screen !== currentScreen || tab === 'options';
      });
      zoneDpad.hidden         = tab !== 'remote';
      zoneOptionsPanel.hidden = tab !== 'options';
    } else {
      var isDpad = DPAD_SCREENS.has(currentScreen);
      zoneOptionsPanel.hidden = tab !== 'options';
      zoneDpad.hidden         = !isDpad || tab === 'options';
    }

    if (tab === 'game') remoteDot.hidden = true;
  }

  document.querySelectorAll('.zone-tab').forEach(function(btn) {
    btn.addEventListener('click', function() { applyTab(btn.dataset.tab); });
  });

  // ── TV Remote channel ────────────────────────────────────────────────
  var consumer = createConsumer();

  function connectToTv() {
    remote = consumer.subscriptions.create(
      { channel: 'TvRemoteChannel', token: token, device_token: deviceToken },
      {
        connected: function() {
          zoneDot.classList.add('live');
          zoneStatus.textContent = 'Connected';
          if (currentScreen === 'disconnected' || currentScreen === 'claim') showScreen('shelf');
        },
        disconnected: function() {
          zoneDot.classList.remove('live');
          zoneStatus.textContent = 'Disconnected';
          showScreen('disconnected');
        },
        received: function(data) {
          if (data.type === 'tv_state')   handleTvState(data);
          if (data.type === 'joined')     handleJoined(data);
          if (data.type === 'join_error') handleJoinError(data);
          if (data.type === 'rejoined')   handleRejoined(data);
          if (data.type === 'slot_assigned') handleSlotAssigned(data);
          if (data.type === 'left')       handleLeft();
          // 'navigate' events are ignored on the phone
        }
      }
    );
  }

  // ── Startup: claim or connect ────────────────────────────────────────
  if (deviceToken) {
    connectToTv();
  } else {
    showScreen('claim');
  }

  // ── Claim helpers ────────────────────────────────────────────────────
  function showClaimStep(step) {
    claimNameStep.hidden   = step !== 'name';
    pinSetupStep.hidden    = step !== 'pin-setup';
    pinLoginStep.hidden    = step !== 'pin-login';
  }

  function storeAndConnect(data) {
    localStorage.setItem('ezaz_device_token', data.device_token);
    localStorage.setItem('ezaz_username', data.username);
    deviceToken = data.device_token;
    myUsername  = data.username;
    connectToTv();
    showScreen('shelf');
  }

  // Step 1: name entry
  claimBtn.addEventListener('click', function() {
    var name = claimInput.value.trim();
    if (!name) { claimError.textContent = 'Enter a name first'; claimError.hidden = false; return; }
    claimBtn.disabled = true;
    claimBtn.textContent = 'Checking…';
    claimError.hidden = true;
    fetch('/api/players/claim', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: name })
    })
    .then(function(r) { return r.json().then(function(d) { return { status: r.status, data: d }; }); })
    .then(function(res) {
      if (res.status === 201) {
        localStorage.setItem('ezaz_device_token', res.data.device_token);
        localStorage.setItem('ezaz_username', res.data.username);
        deviceToken = res.data.device_token;
        myUsername  = res.data.username;
        connectToTv();
        showClaimStep('pin-setup');
        setTimeout(function() { pinSetupInput.focus(); }, 50);
      } else if (res.status === 409) {
        pinLoginTitle.textContent = 'Welcome back, ' + name.toUpperCase() + '!';
        pinLoginInput.value = '';
        pinLoginError.hidden = true;
        showClaimStep('pin-login');
        setTimeout(function() { pinLoginInput.focus(); }, 50);
      } else {
        claimError.textContent = res.data.error || 'Could not save name';
        claimError.hidden = false;
        claimBtn.disabled = false;
        claimBtn.textContent = 'Let\'s Go →';
      }
    })
    .catch(function() {
      claimError.textContent = 'Connection error — try again';
      claimError.hidden = false;
      claimBtn.disabled = false;
      claimBtn.textContent = 'Let\'s Go →';
    });
  });

  claimInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') claimBtn.click(); });

  // Step 2a: PIN setup (after successful claim)
  pinSetupBtn.addEventListener('click', function() {
    var pin = pinSetupInput.value.trim();
    if (pin.length !== 4 || !/^\d{4}$/.test(pin)) {
      pinSetupError.textContent = 'Enter exactly 4 digits';
      pinSetupError.hidden = false;
      return;
    }
    pinSetupBtn.disabled = true;
    pinSetupBtn.textContent = 'Saving…';
    pinSetupError.hidden = true;
    fetch('/api/players/pin', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ device_token: deviceToken, pin: pin })
    })
    .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
    .then(function(res) {
      if (res.ok) {
        showScreen('shelf');
      } else {
        pinSetupError.textContent = res.data.error || 'Could not save PIN';
        pinSetupError.hidden = false;
        pinSetupBtn.disabled = false;
        pinSetupBtn.textContent = 'Save PIN →';
      }
    })
    .catch(function() {
      pinSetupError.textContent = 'Connection error — try again';
      pinSetupError.hidden = false;
      pinSetupBtn.disabled = false;
      pinSetupBtn.textContent = 'Save PIN →';
    });
  });

  pinSetupSkipBtn.addEventListener('click', function() { showScreen('shelf'); });
  pinSetupInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') pinSetupBtn.click(); });

  // Step 2b: PIN login (name already taken)
  pinLoginBtn.addEventListener('click', function() {
    var name = claimInput.value.trim().toUpperCase();
    var pin  = pinLoginInput.value.trim();
    if (pin.length !== 4 || !/^\d{4}$/.test(pin)) {
      pinLoginError.textContent = 'Enter your 4-digit PIN';
      pinLoginError.hidden = false;
      return;
    }
    pinLoginBtn.disabled = true;
    pinLoginBtn.textContent = 'Checking…';
    pinLoginError.hidden = true;
    fetch('/api/players/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: name, pin: pin })
    })
    .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
    .then(function(res) {
      if (res.ok) {
        storeAndConnect(res.data);
      } else {
        pinLoginError.textContent = res.data.error || 'Login failed';
        pinLoginError.hidden = false;
        pinLoginBtn.disabled = false;
        pinLoginBtn.textContent = 'Log In →';
      }
    })
    .catch(function() {
      pinLoginError.textContent = 'Connection error — try again';
      pinLoginError.hidden = false;
      pinLoginBtn.disabled = false;
      pinLoginBtn.textContent = 'Log In →';
    });
  });

  pinLoginInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') pinLoginBtn.click(); });
  pinBackBtn.addEventListener('click', function() {
    claimBtn.disabled = false;
    claimBtn.textContent = 'Let\'s Go →';
    claimError.hidden = true;
    showClaimStep('name');
    setTimeout(function() { claimInput.focus(); }, 50);
  });

  function handleTvState(data) {
    if (data.room_code)  { roomCode = data.room_code; lobbyRoomCode.textContent = 'Room ' + data.room_code; }
    if (data.game_title) { lobbyGameName.textContent = data.game_title; }

    if (data.state === 'shelf') {
      fireBtn.hidden = true;
      if (!mySlot) showScreen('shelf');
    } else if (data.state === 'lobby') {
      fireBtn.hidden = true;
      if (mySlot) showScreen('waiting');
      else        showScreen('lobby');
    } else if (data.state === 'game') {
      fireBtn.hidden = false;
      if (!mySlot) showScreen('watching');
      // if mySlot is set the buzzer is driven by TriviaChannel events
    }
  }

  function handleJoined(data) {
    mySlot   = data.slot;
    myColor  = data.color;
    roomCode = data.code;
    gameSlug = data.game_slug || gameSlug;

    waitingBadge.textContent = 'P' + mySlot;
    waitingBadge.style.background = myColor;
    document.documentElement.style.setProperty('--buzz-color', myColor);
    buzzerInfo.textContent = 'P' + mySlot;
    document.getElementById('spot-info').textContent = 'P' + mySlot;
    document.getElementById('th-info').textContent = 'P' + mySlot;
    document.getElementById('hk-info').textContent = 'P' + mySlot;

    if (data.members) renderPlayers(data.members);
    showScreen('waiting');
    subscribeToGameChannel(data.code, data.slot);
    subscribeToRoom(data.code);
  }

  function handleRejoined(data) {
    mySlot  = data.slot;
    myColor = data.color;
    gameSlug = data.game_slug || gameSlug;
    if (data.code) roomCode = data.code;
    waitingBadge.textContent = 'P' + mySlot;
    waitingBadge.style.background = myColor;
    document.documentElement.style.setProperty('--buzz-color', myColor);
    buzzerInfo.textContent = 'P' + mySlot;
    document.getElementById('spot-info').textContent = 'P' + mySlot;
    document.getElementById('th-info').textContent = 'P' + mySlot;
    document.getElementById('hk-info').textContent = 'P' + mySlot;
    if (roomCode && mySlot) {
      subscribeToGameChannel(roomCode, mySlot);
      subscribeToRoom(roomCode);
    }
  }

  function subscribeToGameChannel(code, slot) {
    if (gameSlug === 'spotlight') subscribeToSpotlight(code, slot);
    else if (gameSlug === 'treasure-hunt') subscribeToTreasure(code, slot);
    else if (gameSlug === 'hacker-pro') subscribeToHacker(code, slot);
    else if (gameSlug === 'boomerang-brawl') subscribeToBoomerang(code, slot);
    else subscribeToTrivia(code, slot);
  }

  function handleSlotAssigned(data) {
    if (data.phone_id !== deviceToken) return;
    mySlot  = data.slot;
    myColor = data.color;
  }

  function renderPlayers(members) {
    var rows = members.filter(function(m) { return m.role === 'player'; }).map(function(m) {
      var color = SLOT_COLORS[m.slot] || '#fff';
      var youTag = m.slot === mySlot ? '<span class="waiting-player-you">YOU</span>' : '';
      return '<div class="waiting-player-row">' +
        '<div class="waiting-player-dot" style="background:' + color + '"></div>' +
        '<div class="waiting-player-name">' + esc(m.name) + '</div>' +
        youTag +
        '</div>';
    });
    waitingPlayers.innerHTML =
      '<div class="waiting-players-title">In the room</div>' +
      (rows.length ? rows.join('') : '<div class="waiting-player-row" style="color:#445;font-size:13px;">Just you so far…</div>');
  }

  function subscribeToRoom(code) {
    if (roomChannel) return;
    roomChannel = consumer.subscriptions.create(
      { channel: 'RoomChannel', code: code },
      {
        received: function(data) {
          if (data.type === 'member_joined' || data.type === 'member_left') {
            if (data.members) renderPlayers(data.members);
          }
        }
      }
    );
  }

  function handleJoinError(data) {
    joinError.textContent = data.message;
    joinError.hidden = false;
    joinBtn.disabled = false;
    joinBtn.textContent = 'Join Game →';
  }

  // ── Leave game ────────────────────────────────────────────────────────
  leaveGameBtn.addEventListener('click', function() {
    remote.perform('leave_room', {});
  });

  function handleLeft() {
    mySlot  = null;
    myColor = null;
    if (roomChannel) { roomChannel.unsubscribe(); roomChannel = null; }
    if (triviaChannel) { triviaChannel.unsubscribe(); triviaChannel = null; }
    if (spotlightChannel) { spotlightChannel.unsubscribe(); spotlightChannel = null; }
    if (treasureChannel)  { treasureChannel.unsubscribe();  treasureChannel = null; }
    if (hackerChannel)    { hackerChannel.unsubscribe();    hackerChannel = null; }
    if (boomerangChannel) { boomerangChannel.unsubscribe(); boomerangChannel = null; }
    showScreen('lobby');
  }

  // ── Join form ─────────────────────────────────────────────────────────
  joinBtn.addEventListener('click', function() {
    var name = nameInput.value.trim();
    if (!name) { showJoinError('Enter your name first'); return; }
    if (!roomCode) { showJoinError('No game open on TV'); return; }
    joinError.hidden = true;
    joinBtn.disabled = true;
    joinBtn.textContent = 'Joining…';
    remote.perform('join_room', { code: roomCode, name: name });
  });

  nameInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') joinBtn.click();
  });

  function showJoinError(msg) {
    joinError.textContent = msg;
    joinError.hidden = false;
  }

  // ── Trivia subscription ───────────────────────────────────────────────
  function subscribeToTrivia(code, slot) {
    if (triviaChannel) return;
    triviaChannel = consumer.subscriptions.create(
      { channel: 'TriviaChannel', code: code, slot: slot },
      {
        received: function(data) {
          switch (data.type) {
            case 'question':        onQuestion(data);       break;
            case 'answering':       onAnswering(data);      break;
            case 'player_answered': onPlayerAnswered(data); break;
            case 'revealed':        onRevealed(data);       break;
            case 'game_over':       onGameOver(data);       break;
          }
        }
      }
    );
  }

  // ── Spotlight subscription ────────────────────────────────────────────
  function subscribeToSpotlight(code, slot) {
    if (spotlightChannel) return;
    spotlightChannel = consumer.subscriptions.create(
      { channel: 'SpotlightChannel', code: code, slot: slot },
      {
        received: function(data) {
          switch (data.type) {
            case 'question':         onSpotQuestion(data);    break;
            case 'answering':        onSpotAnswering(data);   break;
            case 'player_submitted': onSpotSubmitted(data);   break;
            case 'picking':          onSpotPicking(data);     break;
            case 'revealed':         onSpotRevealed(data);    break;
            case 'game_over':        onSpotGameOver(data);    break;
          }
        }
      }
    );
  }

  function showSpotPhase(name) {
    document.getElementById('spot-reading-state').hidden = name !== 'reading';
    document.getElementById('spot-typing-state').hidden  = name !== 'typing';
    document.getElementById('spot-locked-state').hidden  = name !== 'locked';
    document.getElementById('spot-picking-state').hidden = name !== 'picking';
    document.getElementById('spot-result-state').hidden  = name !== 'result';
  }

  function setSpotBanner(spotlightSlot, spotlightName) {
    var banner = document.getElementById('spot-banner');
    var nameEl = document.getElementById('spot-banner-name');
    var iAm = (spotlightSlot === mySlot);
    banner.classList.toggle('is-me', iAm);
    nameEl.textContent = iAm ? 'YOU' : spotlightName;
  }

  function onSpotQuestion(data) {
    spotState.phase = 'reading';
    spotState.spotlightSlot = data.spotlight_slot;
    document.getElementById('spot-info').textContent = 'P' + mySlot + '  ·  Q' + (data.q_index + 1) + ' / ' + data.total;
    document.getElementById('spot-question').textContent = data.question;
    document.getElementById('spot-question-2').textContent = data.question;
    setSpotBanner(data.spotlight_slot, data.spotlight_name);

    var promptEl = document.getElementById('spot-reading-prompt');
    promptEl.innerHTML = (data.spotlight_slot === mySlot)
      ? "You're up! Get ready to type your real answer."
      : "Get ready to guess what <b>" + esc(data.spotlight_name) + "</b> would say.";

    showSpotPhase('reading');
    showScreen('spotlight');
    if (activeTab === 'remote') { remoteDot.hidden = false; } else { applyTab('game'); }
  }

  function onSpotAnswering(data) {
    spotState.phase = 'answering';
    var input = document.getElementById('spot-input');
    var promptEl = document.getElementById('spot-typing-prompt');
    var submitBtn = document.getElementById('spot-submit-btn');
    var iAm = (spotState.spotlightSlot === mySlot);

    if (iAm) {
      input.classList.add('is-spotlight');
      input.placeholder = 'Your real answer';
      promptEl.innerHTML = "You're in the spotlight! Type your <b>real</b> answer — others guess what you'll say.";
    } else {
      input.classList.remove('is-spotlight');
      input.placeholder = 'Your guess';
      promptEl.innerHTML = "What do you think <b>" + esc(data.spotlight_name) + "</b> will say?";
    }
    input.value = '';
    input.disabled = false;
    submitBtn.disabled = false;
    submitBtn.textContent = 'Lock it in →';

    showSpotPhase('typing');
    if (activeTab !== 'options') applyTab('game');
    setTimeout(function() { input.focus(); }, 80);
  }

  function submitSpotAnswer() {
    if (!spotlightChannel) return;
    var input = document.getElementById('spot-input');
    var submitBtn = document.getElementById('spot-submit-btn');
    var text = input.value.trim();
    if (!text) return;
    spotlightChannel.perform('submit', { text: text });
    input.disabled = true;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Locked';
    if (navigator.vibrate) navigator.vibrate(40);
  }

  document.getElementById('spot-submit-btn').addEventListener('click', submitSpotAnswer);
  document.getElementById('spot-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); submitSpotAnswer(); }
  });

  function onSpotSubmitted(data) {
    if (data.slot === mySlot) {
      var msg = document.getElementById('spot-locked-msg');
      msg.innerHTML = 'Locked in!<br>' + data.submitted_count + ' / ' + data.expected_count + ' in';
      showSpotPhase('locked');
      if (navigator.vibrate) navigator.vibrate(60);
    } else {
      // update count if I'm currently locked
      if (!document.getElementById('spot-locked-state').hidden) {
        document.getElementById('spot-locked-msg').innerHTML =
          'Locked in!<br>' + data.submitted_count + ' / ' + data.expected_count + ' in';
      }
    }
  }

  function onSpotPicking(data) {
    spotState.phase = 'picking';
    var iAm = (data.spotlight_slot === mySlot);
    var msgEl = document.getElementById('spot-picking-msg');
    var listEl = document.getElementById('spot-pick-list');

    if (iAm) {
      msgEl.innerHTML = '<b>You\'re picking!</b><br>Choose your favourite answer.';
      listEl.innerHTML = '';
      data.submissions.forEach(function(sub) {
        if (sub.is_spotlight) return;
        var btn = document.createElement('button');
        btn.className = 'spot-pick-btn';
        btn.style.setProperty('--pick-color', sub.color);
        btn.innerHTML =
          '<div class="spot-pick-dot" style="background:' + sub.color + '"></div>' +
          '<div>' +
            '<div class="spot-pick-name" style="color:' + sub.color + '">' + esc(sub.name) + '</div>' +
            esc(sub.text) +
          '</div>';
        btn.addEventListener('click', function() {
          if (!spotlightChannel) return;
          spotlightChannel.perform('pick', { picked_slot: sub.slot });
          listEl.querySelectorAll('button').forEach(function(b) { b.disabled = true; });
          if (navigator.vibrate) navigator.vibrate(40);
          // Safety: if no reveal arrives in 5s, re-enable buttons so the
          // spotlight can tap again (covers connection hiccups / lost packets).
          setTimeout(function() {
            if (spotState.phase === 'picking') {
              listEl.querySelectorAll('button').forEach(function(b) { b.disabled = false; });
            }
          }, 5000);
        });
        listEl.appendChild(btn);
      });
      showSpotPhase('picking');
    } else {
      msgEl.innerHTML = '<b>' + esc(data.spotlight_name) + '</b> is picking their favourite…<br>Watch the TV!';
      listEl.innerHTML = '';
      showSpotPhase('picking');
    }
  }

  function onSpotRevealed(data) {
    spotState.phase = 'revealed';
    var iconEl = document.getElementById('spot-result-icon');
    var msgEl  = document.getElementById('spot-result-msg');
    var iAmSpot = (data.spotlight_slot === mySlot);
    var myResult = data.submissions.find(function(s) { return s.slot === mySlot; });

    if (iAmSpot) {
      iconEl.textContent = '🌟'; iconEl.style.color = '#ffd700';
      msgEl.innerHTML = 'Your answer:<br><b>' + esc(data.spotlight_answer) + '</b><br><br>Check the TV for results!';
    } else if (!myResult) {
      iconEl.textContent = '→'; iconEl.style.color = '#8ab4c8';
      msgEl.textContent = 'Next round coming up…';
    } else {
      var bits = [];
      if (myResult.matched) bits.push('<span style="color:#2ed573">✓ Matched +2</span>');
      if (myResult.picked)  bits.push('<span style="color:#ffd700">👑 Favourite +3</span>');
      if (bits.length) {
        iconEl.textContent = myResult.picked ? '👑' : '✓';
        iconEl.style.color = myResult.picked ? '#ffd700' : '#2ed573';
        msgEl.innerHTML = bits.join('<br>') + '<br><br>The answer was:<br><b>' + esc(data.spotlight_answer) + '</b>';
        if (navigator.vibrate) navigator.vibrate([40, 30, 60]);
      } else {
        iconEl.textContent = '✗'; iconEl.style.color = '#ff4757';
        msgEl.innerHTML = 'No luck this round.<br>The answer was:<br><b>' + esc(data.spotlight_answer) + '</b>';
      }
    }
    showSpotPhase('result');
  }

  function onSpotGameOver(data) {
    var iconEl = document.getElementById('spot-result-icon');
    var msgEl  = document.getElementById('spot-result-msg');
    iconEl.textContent = '🏆'; iconEl.style.color = '#ffd700';
    msgEl.innerHTML = 'Game over!<br>Check the TV for results.';
    var existingLink = msgEl.parentElement.querySelector('.back-to-store');
    if (!existingLink) {
      var link = document.createElement('a');
      link.href = '/'; link.className = 'back-to-store';
      link.textContent = '← Back to Store';
      msgEl.insertAdjacentElement('afterend', link);
    }
    showSpotPhase('result');
  }

  // ── Treasure Hunt subscription ────────────────────────────────────────
  var thState = { hand: [], selected: null, locked: null, totalRounds: 5, lastChallenge: null };

  function subscribeToTreasure(code, slot) {
    if (treasureChannel) return;
    treasureChannel = consumer.subscriptions.create(
      { channel: 'TreasureChannel', code: code, slot: slot },
      {
        received: function(data) {
          switch (data.type) {
            case 'deal':          onThDeal(data);         break;
            case 'round':         onThRound(data);        break;
            case 'picking':       onThPicking(data);      break;
            case 'player_played': onThPlayerPlayed(data); break;
            case 'revealed':      onThRevealed(data);     break;
            case 'game_over':     onThGameOver(data);     break;
          }
        }
      }
    );
  }

  function showThPhase(name) {
    document.getElementById('th-hand').hidden        = !(name === 'reading' || name === 'picking');
    document.getElementById('th-confirm-btn').hidden = !(name === 'reading' || name === 'picking');
    document.getElementById('th-locked-wrap').hidden = name !== 'locked';
    document.getElementById('th-result-wrap').hidden = name !== 'result';
  }

  var COLOUR_SUIT = { red: '♥', blue: '♠', green: '♣', yellow: '♦' };

  function onThDeal(data) {
    if (data.slot !== mySlot) return;
    thState.hand = data.hand || [];
    thState.selected = null;
    thState.locked = null;
    renderHand();
  }

  function onThRound(data) {
    thState.totalRounds = data.total;
    thState.lastChallenge = data.challenge;
    thState.selected = null;
    thState.locked = null;
    document.getElementById('th-info').textContent = 'P' + mySlot + '  ·  R' + (data.round + 1) + ' / ' + data.total;
    document.getElementById('th-banner-round').textContent = 'Round ' + (data.round + 1) + ' of ' + data.total;
    document.getElementById('th-banner-label').textContent = data.challenge.label;
    document.getElementById('th-banner-hint').textContent  = data.challenge.hint;
    document.getElementById('th-status-line').innerHTML = 'Get ready…';
    document.getElementById('th-confirm-btn').disabled = true;
    document.getElementById('th-confirm-btn').textContent = 'Lock it in →';
    showThPhase('reading');
    showScreen('treasure');
    if (activeTab === 'remote') { remoteDot.hidden = false; } else { applyTab('game'); }
    renderHand({ disabled: true });
  }

  function onThPicking(data) {
    document.getElementById('th-status-line').innerHTML = 'Pick a card. <b>' + data.expected_count + '</b> players in.';
    document.getElementById('th-confirm-btn').disabled = true;
    showThPhase('picking');
    if (activeTab !== 'options') applyTab('game');
    renderHand({ disabled: false });
  }

  function onThPlayerPlayed(data) {
    if (data.slot === mySlot) return;
    document.getElementById('th-status-line').innerHTML =
      '<b>' + data.played_count + ' / ' + data.expected_count + '</b> played.';
  }

  function onThRevealed(data) {
    var iconEl = document.getElementById('th-result-icon');
    var msgEl  = document.getElementById('th-result-msg');
    var iWon = data.winners.indexOf(String(mySlot)) !== -1 || data.winners.indexOf(mySlot) !== -1;
    var myPlay = data.plays.find(function(p) { return p.slot === mySlot; });
    var winnerNames = data.plays.filter(function(p) { return p.winner; }).map(function(p) { return esc(p.name); });

    if (data.winners.length === 0) {
      iconEl.textContent = '✗'; iconEl.style.color = '#ff4757';
      msgEl.innerHTML = 'No winner this round.<br>All cards discarded.';
    } else if (iWon && data.winners.length === 1) {
      iconEl.textContent = '👑'; iconEl.style.color = '#ffd700';
      msgEl.innerHTML = 'You won the round!<br>You take the pot.';
      if (navigator.vibrate) navigator.vibrate([60, 30, 80]);
    } else if (iWon) {
      iconEl.textContent = '🤝'; iconEl.style.color = '#ffd700';
      msgEl.innerHTML = 'Tied for the win!<br>You keep your card.';
      if (navigator.vibrate) navigator.vibrate(50);
    } else {
      iconEl.textContent = '·'; iconEl.style.color = '#8ab4c8';
      msgEl.innerHTML = (winnerNames.length ? '<b>' + winnerNames.join(' &amp; ') + '</b> won.' : 'No winner.') +
                        '<br>You played ' + (myPlay ? myPlay.card.value + COLOUR_SUIT[myPlay.card.colour] : '—') + '.';
    }
    showThPhase('result');
  }

  function onThGameOver(data) {
    var iconEl = document.getElementById('th-result-icon');
    var msgEl  = document.getElementById('th-result-msg');
    iconEl.textContent = '🏆'; iconEl.style.color = '#ffd700';
    msgEl.innerHTML = 'Game over!<br>Check the TV for the treasure tally.';
    var existingLink = msgEl.parentElement.querySelector('.back-to-store');
    if (!existingLink) {
      var link = document.createElement('a');
      link.href = '/'; link.className = 'back-to-store';
      link.textContent = '← Back to Store';
      msgEl.insertAdjacentElement('afterend', link);
    }
    showThPhase('result');
  }

  function renderHand(opts) {
    opts = opts || {};
    var handEl = document.getElementById('th-hand');
    handEl.innerHTML = '';
    handEl.classList.toggle('is-locked', !!opts.disabled);
    thState.hand.forEach(function(card) {
      var btn = document.createElement('button');
      btn.className = 'th-card-btn';
      btn.setAttribute('data-colour', card.colour);
      btn.setAttribute('data-card-id', card.id);
      var suit = COLOUR_SUIT[card.colour] || '◆';
      btn.innerHTML =
        '<div class="th-card-corner"><div>' + card.value + '</div><div class="th-card-corner-suit">' + suit + '</div></div>' +
        '<div class="th-card-centre">' + card.value + '</div>' +
        '<div class="th-card-corner-bottom"><div>' + card.value + '</div><div class="th-card-corner-suit">' + suit + '</div></div>';
      if (thState.selected === card.id) btn.classList.add('is-selected');
      btn.addEventListener('click', function() {
        if (opts.disabled) return;
        thState.selected = card.id;
        document.getElementById('th-confirm-btn').disabled = false;
        handEl.querySelectorAll('.th-card-btn').forEach(function(b) { b.classList.remove('is-selected'); });
        btn.classList.add('is-selected');
        if (navigator.vibrate) navigator.vibrate(20);
      });
      handEl.appendChild(btn);
    });
  }

  document.getElementById('th-confirm-btn').addEventListener('click', function() {
    if (!treasureChannel || !thState.selected) return;
    var card = thState.hand.find(function(c) { return c.id === thState.selected; });
    if (!card) return;
    treasureChannel.perform('play_card', { card_id: card.id });
    thState.locked = card;
    thState.hand = thState.hand.filter(function(c) { return c.id !== card.id; });
    thState.selected = null;
    renderLockedCard(card);
    if (navigator.vibrate) navigator.vibrate(60);
    showThPhase('locked');
  });

  function renderLockedCard(card) {
    var el = document.getElementById('th-locked-card');
    el.setAttribute('data-colour', card.colour);
    var suit = COLOUR_SUIT[card.colour] || '◆';
    el.innerHTML =
      '<div class="th-card-corner" style="font-size:14px"><div>' + card.value + '</div><div class="th-card-corner-suit">' + suit + '</div></div>' +
      '<div class="th-card-centre" style="font-size:36px;align-self:center">' + card.value + '</div>' +
      '<div class="th-card-corner-bottom" style="font-size:14px"><div>' + card.value + '</div><div class="th-card-corner-suit">' + suit + '</div></div>';
  }

  // ── Hacker Pro subscription ───────────────────────────────────────────
  var hkState = {
    alphabet: [],
    revealed: [],
    revealedChars: [],
    cursor: 0,
    charIndex: 0,
    label: '',
    length: 0
  };

  function subscribeToHacker(code, slot) {
    if (hackerChannel) return;
    hackerChannel = consumer.subscriptions.create(
      { channel: 'HackerChannel', code: code, slot: slot },
      {
        received: function(data) {
          switch (data.type) {
            case 'playing':     onHkPlaying(data); break;
            case 'slot_solved': onHkSolved(data); break;
            case 'miss':        onHkMiss(data); break;
            case 'won':         onHkWon(data); break;
            case 'reset':       onHkReset(); break;
          }
        }
      }
    );
  }

  function onHkPlaying(data) {
    hkState.alphabet      = data.alphabet || [];
    hkState.revealed      = data.revealed || [];
    hkState.revealedChars = data.revealed_chars || [];
    hkState.label         = data.label || '';
    hkState.length        = data.length || hkState.revealed.length;
    hkState.charIndex     = 0;
    hkState.cursor        = firstUnsolvedIndex();

    document.getElementById('hk-zone-diff').textContent = 'DIFFICULTY ' + (data.label || '—');
    document.getElementById('hk-zone-total').textContent = hkState.length;
    document.getElementById('hk-zone-revealed').textContent = countRevealed();
    document.getElementById('hk-zone-attempts').textContent = data.attempts || 0;
    document.getElementById('hk-zone-feedback').textContent = '';
    document.getElementById('hk-zone-feedback').className = 'hk-zone-feedback';
    document.getElementById('hk-zone-won-state').hidden = true;

    showHkPlayingControls(true);
    renderHkSlots();
    renderHkChar();
    showScreen('hacker');
    if (activeTab === 'remote') { remoteDot.hidden = false; } else { applyTab('game'); }
  }

  function onHkSolved(data) {
    hkState.revealed = data.revealed || hkState.revealed;
    if (data.slot_index != null) {
      hkState.revealedChars[data.slot_index] = data.char;
    }
    document.getElementById('hk-zone-attempts').textContent = data.attempts;
    document.getElementById('hk-zone-revealed').textContent = data.revealed_count || countRevealed();

    if (data.cracked_by === mySlot) {
      var fb = document.getElementById('hk-zone-feedback');
      fb.textContent = '✓ SLOT ' + (data.slot_index + 1) + ' CRACKED';
      fb.className = 'hk-zone-feedback is-hit';
      if (navigator.vibrate) navigator.vibrate([40, 30, 60]);
    }

    // If my cursor was on the now-solved slot, hop to the next unsolved one.
    if (hkState.cursor === data.slot_index) {
      hkState.cursor = firstUnsolvedIndex();
    }
    renderHkSlots();
  }

  function onHkMiss(data) {
    document.getElementById('hk-zone-attempts').textContent = data.attempts;
    if (data.missed_by === mySlot) {
      var fb = document.getElementById('hk-zone-feedback');
      fb.textContent = '✗ ' + data.char + ' wrong on slot ' + (data.slot_index + 1);
      fb.className = 'hk-zone-feedback is-miss';
      if (navigator.vibrate) navigator.vibrate(60);
    }
  }

  function onHkWon(data) {
    document.getElementById('hk-zone-attempts').textContent = data.attempts;
    document.getElementById('hk-zone-won-state').hidden = false;
    document.getElementById('hk-zone-won-msg').innerHTML =
      'ACCESS GRANTED!<br>Code: <b>' + esc((data.code || []).join(' ')) + '</b><br>Check the TV.';
    showHkPlayingControls(false);
  }

  function onHkReset() {
    document.getElementById('hk-zone-feedback').textContent = '';
    showHkPlayingControls(false);
    document.getElementById('hk-zone-won-state').hidden = true;
    showScreen('waiting');
  }

  function showHkPlayingControls(on) {
    document.getElementById('hk-zone-slots').hidden        = !on;
    document.getElementById('hk-zone-prev').parentElement.hidden = !on;
    document.querySelector('#hk-zone-char-display').parentElement.parentElement.hidden = !on;
    document.getElementById('hk-zone-attack').hidden       = !on;
  }

  function countRevealed() {
    return (hkState.revealed || []).reduce(function(acc, r) { return acc + (r ? 1 : 0); }, 0);
  }

  function firstUnsolvedIndex() {
    for (var i = 0; i < hkState.revealed.length; i++) {
      if (!hkState.revealed[i]) return i;
    }
    return 0;
  }

  function nextUnsolved(from, dir) {
    if (hkState.length === 0) return 0;
    var i = from;
    for (var step = 0; step < hkState.length; step++) {
      i = (i + dir + hkState.length) % hkState.length;
      if (!hkState.revealed[i]) return i;
    }
    return from;
  }

  function renderHkSlots() {
    var el = document.getElementById('hk-zone-slots');
    el.innerHTML = '';
    for (var i = 0; i < hkState.length; i++) {
      var s = document.createElement('div');
      s.className = 'hk-zone-slot';
      if (hkState.revealed[i]) {
        s.classList.add('is-locked');
        s.textContent = hkState.revealedChars[i] || '?';
      } else if (i === hkState.cursor) {
        s.classList.add('is-cursor');
        s.textContent = '█';
      } else {
        s.textContent = '█';
      }
      el.appendChild(s);
    }
    var allDone = hkState.length > 0 && countRevealed() >= hkState.length;
    document.getElementById('hk-zone-prev').disabled = allDone;
    document.getElementById('hk-zone-next').disabled = allDone;
    document.getElementById('hk-zone-attack').disabled = allDone;
  }

  function renderHkChar() {
    var ch = hkState.alphabet[hkState.charIndex] || '0';
    document.getElementById('hk-zone-char-display').textContent = ch;
  }

  document.getElementById('hk-zone-prev').addEventListener('click', function() {
    if (!hkState.length) return;
    hkState.cursor = nextUnsolved(hkState.cursor, -1);
    renderHkSlots();
    if (navigator.vibrate) navigator.vibrate(15);
  });
  document.getElementById('hk-zone-next').addEventListener('click', function() {
    if (!hkState.length) return;
    hkState.cursor = nextUnsolved(hkState.cursor, 1);
    renderHkSlots();
    if (navigator.vibrate) navigator.vibrate(15);
  });
  document.getElementById('hk-zone-char-up').addEventListener('click', function() {
    if (!hkState.alphabet.length) return;
    hkState.charIndex = (hkState.charIndex + 1) % hkState.alphabet.length;
    renderHkChar();
    if (navigator.vibrate) navigator.vibrate(10);
  });
  document.getElementById('hk-zone-char-down').addEventListener('click', function() {
    if (!hkState.alphabet.length) return;
    hkState.charIndex = (hkState.charIndex - 1 + hkState.alphabet.length) % hkState.alphabet.length;
    renderHkChar();
    if (navigator.vibrate) navigator.vibrate(10);
  });
  document.getElementById('hk-zone-attack').addEventListener('click', function() {
    if (!hackerChannel || !hkState.alphabet.length) return;
    if (hkState.revealed[hkState.cursor]) return;
    var ch = hkState.alphabet[hkState.charIndex];
    hackerChannel.perform('attempt', { slot_index: hkState.cursor, char: ch });
    if (navigator.vibrate) navigator.vibrate(40);
  });

  // ── Boomerang Brawl subscription ──────────────────────────────────────
  var brZone = {
    alive:       true,
    phase:       'lobby',
    held:        { up: false, down: false, left: false, right: false },
    rangInFlight: false,
    lastThrowAt: 0
  };

  function subscribeToBoomerang(code, slot) {
    if (boomerangChannel) return;
    boomerangChannel = consumer.subscriptions.create(
      { channel: 'BoomerangChannel', code: code, slot: slot },
      {
        connected: function() {
          var dot = document.getElementById('br-zone-dot');
          if (myColor) dot.style.background = myColor;
          document.getElementById('br-zone-name').textContent = 'P' + mySlot;
          document.documentElement.style.setProperty('--my-color', myColor || '#ff8800');
        },
        received: function(data) {
          if (!data) return;
          switch (data.type) {
            case 'tick':       onBrTick(data); break;
            case 'round_over': onBrRoundOver(data); break;
            case 'match_over': onBrMatchOver(data); break;
            case 'reset':      onBrReset(); break;
          }
        }
      }
    );
  }

  function onBrTick(data) {
    if (currentScreen !== 'boomerang') {
      showScreen('boomerang');
      if (activeTab === 'remote') { remoteDot.hidden = false; } else { applyTab('game'); }
    }
    var me = (data.players || []).find(function(p) { return p.slot === mySlot; });
    if (me) {
      brZone.alive = me.alive;
      var statusEl = document.getElementById('br-zone-status');
      var attackBtn = document.getElementById('br-zone-attack');
      var outMsg = document.getElementById('br-zone-out-msg');
      var controls = document.getElementById('br-zone-controls');
      if (me.alive) {
        statusEl.textContent = 'ALIVE';
        statusEl.classList.remove('is-out');
        attackBtn.classList.remove('is-out');
        outMsg.hidden = true;
        controls.style.opacity = 1;
      } else {
        statusEl.textContent = 'OUT';
        statusEl.classList.add('is-out');
        attackBtn.classList.add('is-out');
        outMsg.hidden = false;
        controls.style.opacity = 0.4;
      }
    }
    // Track if my rang is in flight (cooldown UI)
    var mine = (data.boomerangs || []).find(function(b) { return b.owner === mySlot; });
    brZone.rangInFlight = !!mine;
    var attackBtn2 = document.getElementById('br-zone-attack');
    attackBtn2.classList.toggle('is-cooldown', brZone.rangInFlight && brZone.alive);

    // Update round + score pips
    document.getElementById('br-zone-round').textContent = data.round || 1;
    var roundsToWin = data.rounds_to_win || 2;
    var myScore = (data.scores && data.scores[mySlot]) || 0;
    var pipsEl = document.getElementById('br-zone-rounds-pips');
    if (pipsEl.children.length !== roundsToWin) {
      pipsEl.innerHTML = '';
      for (var i = 0; i < roundsToWin; i++) {
        var pip = document.createElement('div');
        pip.className = 'br-zone-rounds-pip';
        pipsEl.appendChild(pip);
      }
    }
    Array.prototype.forEach.call(pipsEl.children, function(pip, idx) {
      pip.classList.toggle('is-on', idx < myScore);
    });

    brZone.phase = data.phase;
  }

  function onBrRoundOver(data) {
    if (navigator.vibrate) navigator.vibrate(40);
  }
  function onBrMatchOver(data) {
    var attackBtn = document.getElementById('br-zone-attack');
    attackBtn.classList.add('is-out');
    var statusEl = document.getElementById('br-zone-status');
    statusEl.textContent = (data.match_winner === mySlot) ? 'CHAMPION' : 'MATCH OVER';
    statusEl.classList.toggle('is-out', data.match_winner !== mySlot);
    if (data.match_winner === mySlot && navigator.vibrate) navigator.vibrate([60, 40, 60, 40, 100]);
  }
  function onBrReset() {
    showScreen('waiting');
  }

  function brSendInput(dir, pressed) {
    if (!boomerangChannel) return;
    if (brZone.held[dir] === pressed) return;
    brZone.held[dir] = pressed;
    boomerangChannel.perform('input', { dir: dir, state: pressed ? 'press' : 'release' });
  }

  function brSendThrow() {
    if (!boomerangChannel || !brZone.alive || brZone.rangInFlight) return;
    var now = performance.now();
    if (now - brZone.lastThrowAt < 120) return; // debounce double-fire
    brZone.lastThrowAt = now;
    boomerangChannel.perform('throw', {});
    if (navigator.vibrate) navigator.vibrate(30);
  }

  // Wire D-pad direction buttons (touch + mouse, with explicit press/release).
  document.querySelectorAll('[data-br-dir]').forEach(function(btn) {
    var dir = btn.dataset.brDir;
    function press(e) {
      e.preventDefault();
      btn.classList.add('pressed');
      brSendInput(dir, true);
    }
    function release(e) {
      if (e) e.preventDefault();
      btn.classList.remove('pressed');
      brSendInput(dir, false);
    }
    btn.addEventListener('touchstart', press, { passive: false });
    btn.addEventListener('touchend', release);
    btn.addEventListener('touchcancel', release);
    btn.addEventListener('mousedown', press);
    btn.addEventListener('mouseup', release);
    btn.addEventListener('mouseleave', function(e) {
      if (btn.classList.contains('pressed')) release(e);
    });
  });

  (function() {
    var btn = document.getElementById('br-zone-attack');
    function press(e) {
      e.preventDefault();
      btn.classList.add('pressed');
      brSendThrow();
    }
    function release(e) {
      if (e) e.preventDefault();
      btn.classList.remove('pressed');
    }
    btn.addEventListener('touchstart', press, { passive: false });
    btn.addEventListener('touchend', release);
    btn.addEventListener('touchcancel', release);
    btn.addEventListener('mousedown', press);
    btn.addEventListener('mouseup', release);
  })();

  // ── Phone timer ───────────────────────────────────────────────────────
  function startPhoneTimer(elId, secs) {
    clearInterval(phoneTimerInterval);
    var el = document.getElementById(elId);
    if (!el) return;
    el.textContent = secs;
    phoneTimerInterval = setInterval(function() {
      secs--;
      el.textContent = secs > 0 ? secs : '';
      if (secs <= 0) clearInterval(phoneTimerInterval);
    }, 1000);
  }

  function clearPhoneTimer() {
    clearInterval(phoneTimerInterval);
  }

  function showBuzzerPhase(name) {
    document.getElementById('phone-reading').hidden   = name !== 'reading';
    document.getElementById('phone-answering').hidden = name !== 'answering';
    document.getElementById('phone-locked').hidden    = name !== 'locked';
    document.getElementById('phone-result').hidden    = name !== 'result';
  }

  // ── Trivia event handlers ─────────────────────────────────────────────
  function onQuestion(data) {
    myAnswerIndex = null;
    buzzerInfo.textContent = 'P' + mySlot + '  ·  Q' + (data.q_index + 1) + ' / ' + data.total;
    document.getElementById('phone-category').textContent = data.category || '';
    document.getElementById('phone-question').textContent = data.question || '';
    showBuzzerPhase('reading');
    showScreen('buzzer');
    startPhoneTimer('phone-read-timer', 10);
    // Pull player back to game tab for each new question; if on remote, show dot instead
    if (activeTab === 'remote') {
      remoteDot.hidden = false;
    } else {
      applyTab('game');
    }
  }

  function onAnswering(data) {
    clearPhoneTimer();
    showBuzzerPhase('answering');
    startPhoneTimer('phone-ans-timer', 10);
    if (activeTab !== 'options') applyTab('game');
    var answersEl = document.getElementById('buzz-answers');
    answersEl.innerHTML = '';
    data.options.forEach(function(opt, i) {
      var btn = document.createElement('button');
      btn.className = 'answer-btn';
      btn.innerHTML = '<span class="aletter">' + letters[i] + '</span>' + esc(opt);
      btn.addEventListener('click', function() {
        if (myAnswerIndex !== null || !triviaChannel) return;
        myAnswerIndex = i;
        triviaChannel.perform('answer', { index: i });
        answersEl.querySelectorAll('.answer-btn').forEach(function(b) { b.disabled = true; });
        if (navigator.vibrate) navigator.vibrate(40);
      });
      answersEl.appendChild(btn);
    });
  }

  function onPlayerAnswered(data) {
    if (data.slot === mySlot) {
      clearPhoneTimer();
      showBuzzerPhase('locked');
      if (navigator.vibrate) navigator.vibrate(60);
    }
  }

  function onRevealed(data) {
    clearPhoneTimer();
    var myResult = data.results && data.results.find(function(r) { return r.slot === mySlot; });
    var iconEl = document.getElementById('phone-result-icon');
    var msgEl  = document.getElementById('phone-result-msg');
    if (myResult) {
      if (myResult.correct) {
        iconEl.textContent = '✓'; iconEl.style.color = '#2ed573';
        msgEl.textContent = 'Correct! +1 point';
        if (navigator.vibrate) navigator.vibrate([50, 30, 50]);
      } else {
        iconEl.textContent = '✗'; iconEl.style.color = '#ff4757';
        msgEl.textContent = 'Wrong! Answer: ' + esc(data.correct_answer || '');
      }
    } else {
      iconEl.textContent = '→'; iconEl.style.color = '#8ab4c8';
      msgEl.textContent = 'Next question coming up…';
    }
    showBuzzerPhase('result');
  }

  function onGameOver(data) {
    clearPhoneTimer();
    var iconEl = document.getElementById('phone-result-icon');
    var msgEl  = document.getElementById('phone-result-msg');
    iconEl.textContent = '🏆'; iconEl.style.color = '#ffd700';
    msgEl.innerHTML = 'Game over!<br>Check the TV for results.';
    var link = document.createElement('a');
    link.href = '/'; link.className = 'back-to-store';
    link.textContent = '← Back to Store';
    msgEl.insertAdjacentElement('afterend', link);
    showBuzzerPhase('result');
  }

  // ── D-pad ─────────────────────────────────────────────────────────────
  function sendNav(dir, navType) {
    if (!remote) return;
    remote.perform('navigate', { direction: dir, nav_type: navType, phone_id: deviceToken });
    if (navType === 'press' && navigator.vibrate) navigator.vibrate(18);
  }

  document.querySelectorAll('[data-dir]').forEach(function(btn) {
    var dir = btn.dataset.dir;
    btn.addEventListener('touchstart', function(e) {
      e.preventDefault();
      btn.classList.add('pressed');
      sendNav(dir, 'press');
    }, { passive: false });
    btn.addEventListener('touchend', function() {
      btn.classList.remove('pressed');
      sendNav(dir, 'release');
    });
    btn.addEventListener('mousedown', function() { btn.classList.add('pressed'); sendNav(dir, 'press'); });
    btn.addEventListener('mouseup',   function() { btn.classList.remove('pressed'); sendNav(dir, 'release'); });
  });

  function esc(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
</script>
